{% extends 'templates/_document.twig' %}

{% block content %}
  <article class="post w-full"
    data-ref="pin"
    data-latitude="{{ post.latitude }}" 
    data-longitude="{{ post.longitude }}">
    <header class="post-header">
      {{ renderComponent('BlockProjectHeader', { post: post }) }}
    </header>
    <section class="post-main max-w-screen-max mx-auto p-sm sm:p-md sm:p-lg flex flex-col sm:flex-row-reverse gap-md sm:gap-sm lg:gap-md justify-between items-start">
      <div class="w-full sm:w-1/2 mdLarge:w-1/3 lg:w-1/3 flex flex-col sm:flex-row lg:flex-col gap-md lg:gap-lg">
        {{ renderComponent('BlockProjectBox', { post: post }) }}
      </div>
      <div class="w-full sm:w-1/2 mdLarge:w-2/3 lg:w-2/3">
        {% if post.intro %}
          <div class="subtitle">{{ post.intro }}</div>
        {% endif %}
        {% for component in post.meta('projectComponents') %}
          {{ renderComponent(component) }}
        {% endfor %}
      {{ renderComponent('BlockCta') }}
      </div>
    </section>
    <section class="post-related">
      {{ renderComponent('RelatedInsights', {'blockTitle': __('Related Insights')}) }}
      {{ renderComponent('RelatedProjects', {'blockTitle': __('Related Projects')}) }}
      {# {% for component in post.meta('relatedProjectComponents') %}
        {{ renderComponent(component) }}
      {% endfor %} #}
    </section>
  </article>
{% endblock %}
