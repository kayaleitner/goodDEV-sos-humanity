<!DOCTYPE html>
<html class="html {{ body_class }}" {{ site.language_attributes }} id="theTop">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="alternate" type="application/rss+xml" title="{{- theme.labels.feed|replace({'%s': site.title}) -}}" href="{{ site.rss2|e('esc_url') }}">
    {{ function('wp_head') }}
  </head>
  <body>
    {{ function('wp_body_open') }}
    {% block layout %}
      <div class="pageWrapper env_badge env_{{function('wp_get_environment_type')}}">
        {% set pid = function('get_queried_object_id') %}
        {% set isPage = function('is_singular', 'page') %}
        {% set headerVariant = isPage ? function('get_field', 'header_variant', pid) : null %}
        {% set footerVariant = isPage ? function('get_field', 'footer_variant', pid) : null %}
        {% if not headerVariant %}
          {% set headerVariant = function('get_field', 'header_variant_default', 'option') ?: 'default' %}
        {% endif %}
        {% if not footerVariant %}
          {% set footerVariant = function('get_field', 'footer_variant_default', 'option') ?: 'default' %}
        {% endif %}
        <header class="{{ headerVariant == 'landing_page' ? 'headerLandingPage' : 'mainHeader headerVariant top-0 left-0 z-[9999] w-full h-0 absolute' }}">
         <a href="#mainContent" class="visuallyHidden visuallyHidden-focusable">
          {{- theme.labels.skipToMainContent|e -}}
        </a>
          {% block header %}
            {% if headerVariant == 'landing_page' %}
              {{ renderComponent('HeaderLandingPage') }}
            {% else %}
              {{ renderComponent('NavigationPreNav') }}
              {{ renderComponent('NavigationMain') }}
              {{ renderComponent('NavigationBurger') }}
              {# {{ renderComponent('NavigationMobile') }} #}
              {# {{ renderComponent('NewsletterMailchimp') }} #}
            {% endif %}
          {% endblock %}
        </header>
        <main id="mainContent" class="mainContent" aria-label="{{- theme.labels.mainContentAriaLabel|e -}}">
          {% if function('post_password_required') %}
            {{ function('get_the_password_form') }}
          {% else %}
            {% block content %}
              No <code>{{ '{% block content %}' }}</code> defined for this template.
            {% endblock %}
          {% endif %}
          <div id="react-job-application-form-root" data-open="0"></div>
        </main>
        <footer class="mainFooter">
          {% block footer %}
            {% if footerVariant == 'landing_page' %}
              {{ renderComponent('FooterLandingPage') }}
              {{ renderComponent('FooterNavigationLandingPageLinklist') }}
              {{ renderComponent('FooterLandingPageNavigation') }}
            {% else %}
              {{ renderComponent('NavigationFooterColumns') }}
              {{ renderComponent('NavigationFooterLinklist') }}
              {{ renderComponent('NavigationFooter') }}
            {% endif %}
          {% endblock %}
        </footer>
        <div class="wpFooter">{{ function('wp_footer') }}</div>
      </div>
    {% endblock %}
  </body>
</html>
