<!DOCTYPE html>
<html class="html {{ body_class }}" {{ site.language_attributes }}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="alternate" type="application/rss+xml" title="{{ site.title }} {{ __('Feed', 'flynt') }}" href="{{ site.rss2|e('esc_url') }}" />
    {{ function('wp_head') }}
  </head>
  <body class="">
    <a href="#mainContent" class="skipLink">{{ __('Skip to main content', 'flynt') }}</a>
    {% block layout %}
      <div class="pageWrapper" data-theme="{{ theme_options.globalThemeOption }}">
        <header class="mainHeader">
          {% block header %}
            {{ renderComponent('NavigationMain') }}
            {{ renderComponent('NavigationBurger') }}
          {% endblock %}
        </header>
        <main id="mainContent" class="mainContent" aria-label="{{ __('Content', 'flynt') }}">
          {% if function('post_password_required') %}
            {{ function('get_the_password_form') }}
          {% else %}
            {% block content %}
              No <code>{{ '{% block content %}' }}</code> defined for this template.
            {% endblock %}
          {% endif %}
          <footer class="mainFooter">
            {% block footer %}
              {{ renderComponent('NavigationFooter') }}
            {% endblock %}
          </footer>
        </main>
        <div class="wpFooter">{{ function('wp_footer') }}</div>
      </div>
    {% endblock %}
  </body>
</html>
