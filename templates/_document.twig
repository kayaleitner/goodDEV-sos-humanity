<!DOCTYPE html>
<html class="html {{ body_class }}" {{ site.language_attributes }}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="alternate" type="application/rss+xml" title="{{ site.title }} {{ __('Feed', 'flynt') }}" href="{{ site.rss2|e('esc_url') }}" />
    <link rel="preload" href="/wp-content/themes/boilerplate-flynt-next/dist/assets/soehne-kraftig.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/wp-content/themes/boilerplate-flynt-next/dist/assets/soehne-halbfett.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/wp-content/themes/boilerplate-flynt-next/dist/assets/soehne-buch.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    {{ function('wp_head') }}
  </head>
  <body class="">
    <a href="#mainContent" class="skipLink">{{ __('Skip to main content', 'flynt') }}</a>
    {% block layout %}
      <div class="pageWrapper">
        <header class="mainHeader fixed top-0 left-0 z-[9999] w-full h-0">
          {% block header %}
            {{ renderComponent('NavigationMain') }}
            {{ renderComponent('NavigationBurger') }}
            {{ renderComponent('NewsletterMailchimp') }}
          {% endblock %}
        </header>
        <main id="mainContent" class="mainContent" aria-label="{{ __('Content', 'flynt') }}">
          {% if function('post_password_required') %}
            {{ function('get_the_password_form') }}
          {% else %}
            {% block content %}
              No <code>{{ '{% block content %}' }}</code> defined for this template.
            {% endblock %}
          {% endif %}
        </main>
        <footer class="mainFooter">
          {% block footer %}
            {{ renderComponent('NavigationFooter') }}
          {% endblock %}
        </footer>
        <div class="wpFooter">{{ function('wp_footer') }}</div>
      </div>
    {% endblock %}
  </body>
</html>
