<!DOCTYPE html>
<html class="html {{ body_class }}" {{ site.language_attributes }}>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="alternate" type="application/rss+xml" title="{{- theme.labels.feed|replace({'%s': site.title}) -}}" href="{{ site.rss2|e('esc_url') }}">
    {{ function('wp_head') }}
  </head>
  <body>
    {{ function('wp_body_open') }}
    <a href="#mainContent" class="visuallyHidden visuallyHidden-focusable">
      {{- theme.labels.skipToMainContent|e -}}
    </a>
    {% block layout %}
      <div class="pageWrapper env_badge env_{{function('wp_get_environment_type')}}">
        <header class="mainHeader top-0 left-0 z-[9999] w-full h-0 absolute">
          {% block header %}
            {{ renderComponent('NavigationPreNav') }}
            {{ renderComponent('NavigationMain') }}
            {# {{ renderComponent('NavigationMobile') }} #}
            {# {{ renderComponent('NewsletterMailchimp') }} #}
          {% endblock %}
        </header>
        <main id="mainContent" class="mainContent" aria-label="{{- theme.labels.mainContentAriaLabel|e -}}">
          {% if function('post_password_required') %}
            {{ function('get_the_password_form') }}
          {% else %}
            {% block content %}
              No <code>{{ '{% block content %}' }}</code> defined for this template.
            {% endblock %}
          {% endif %}
        </main>
        <footer class="mainFooter">
          {% block footer %}
            {{ renderComponent('NavigationFooterColumns') }}
            {{ renderComponent('NavigationFooterLinklist') }}
            {{ renderComponent('NavigationFooter') }}
          {% endblock %}
        </footer>
        <div class="wpFooter">{{ function('wp_footer') }}</div>
      </div>
    {% endblock %}
  </body>
</html>
