{% extends 'templates/_document.twig' %}

{% block content %}
  <article class="
      post mt-[134px] 
      w-full max-w-screen-xl mx-auto 
      p-sm lg:p-lg ">
    <section class="flex flex-col">
      <section class="post-header">
        {{ renderComponent('BlockInsightHeader', { post: post }) }}
      </section>
      <section class="post-main mt-lg">
        {% if post.post_excerpt %}
          <div class="w-full lg:w-2/3">
            <div class="h3">{{ post.post_excerpt }}</div>
          </div>
        {% endif %}
        {% for component in post.meta('postComponents') %}
          {{ renderComponent(component) }}
        {% endfor %}
      </section>
    </section>
    <section class="post-related">
      {{ renderComponent('ListingInsights,', {'preContentHtml': '<h2>' ~ __('Related Posts') ~ '</h2>','taxonomies': post.categories(), 'options': {'maxColumns': 3}}) }}
    </section>
  </article>
{% endblock %}
