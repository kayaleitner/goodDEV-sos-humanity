{% extends 'templates/_document.twig' %}

{% block content %}
  {% set array = [] %}
  {% for comp in post.meta('pageComponents') %}
      {% set array = array|merge([comp|first]) %}
  {% endfor %}

  {% set excludedFirstComponents = ['heroImageText', 'BlockHeroVideo'] %}
  {% if array[0] not in excludedFirstComponents %}
    {{ renderComponent('BlockPostHeader', {'post': post}) }}
  {% endif %}


  {% for component in post.meta('pageComponents') %}
    {{ renderComponent(component) }}
  {% endfor %}
{% endblock %}
