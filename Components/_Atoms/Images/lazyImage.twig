
{% macro lazyImage(params = {}) %}
    <img 
        class="{{ params.eager ? '' : 'lazyload' }} w-full h-full object-cover {{ params.class | default('') }}"
        src="{{ params.eager ? params.image.src : params.image.src|resize(32) }}"
        {% if not params.eager %}
            data-src="{{ params.image.src }}"
            data-srcset="{{ function('wp_get_attachment_image_srcset', params.image.id) }}" 
            data-sizes="auto"
        {% else %}
            srcset="{{ function('wp_get_attachment_image_srcset', params.image.id) }}" 
            sizes="auto"
            loading="eager"
        {% endif %}
        alt="{{ params.image.alt|e | default('') }}"
        width="{{ params.width | default('') }}"
        height="{{ params.height | default('') }}"
    />
{% endmacro %}
