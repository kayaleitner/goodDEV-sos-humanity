{% macro lazyImage(image, class, width, height) %}
    <img 
        class="lazyload {{ class | default('') }}"
        src="{{image.src|resize(32)}}"
        data-src="{{ image.src }}"
        data-srcset="{{ function('wp_get_attachment_image_srcset', image.id) }}" 
        data-sizes="auto" 
        alt="{{ image.alt|e | default('') }}"
        width="{{ width | default('')}}"
        height="{{ height | default('') }}"
        loading="lazy"
    />
{% endmacro %}