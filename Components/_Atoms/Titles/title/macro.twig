{% macro hCls(args = { }) %}
    {% with args %}
        {% if font %}
            {{ font }}
        {% else %}
          {% if level == 1 %}
              font-pageTitle
          {% elseif level == 2 %}
              font-sectionTitle
          {% elseif level == 3 %}
              font-contentTitle
          {% endif %}
        {% endif %}
    {% endwith %}
{% endmacro %}

{% macro hStart(args = { }) %}
  {% with args %}
    <h{{ level|default(2) }}
      class="{{ class }} {{ _self.hCls(args) }}"
    >
  {% endwith %}
{% endmacro %}

{% macro hEnd(args = { }) %}
  {% with args %}
    </h{{ level|default(2) }}>
  {% endwith %}
{% endmacro %}

{% macro h(text, args = { }) %}
  {{ _self.hStart(args) }}
    {{ text }}
  {{ _self.hEnd(args) }}
{% endmacro %}
