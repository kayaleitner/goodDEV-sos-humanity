<flynt-component
  load:on="visible"
  name="BlockImageTextFull"
  class=""
  {{ options.theme ? 'data-theme="' ~ options.theme ~ '"' }}
  {{ options.navStyle ? 'data-navStyle="' ~ options.navStyle ~ '"' }}
>
<div class="sm:h-[600px] lg:h-[900px] flex {% if imagePosition is defined and imagePosition == 'left' %}flex-col-reverse sm:flex-row{% elseif imagePosition is defined and imagePosition == 'right' %}flex-col-reverse sm:flex-row-reverse{% else %}flex-col sm:flex-reverse{% endif %}"
    style="background-color: {% if options.colorBackground %}{{ options.colorBackground }}{% else %}var(--brandColor){% endif %};">
    <figure class="w-full sm:w-1/2 overflow-hidden">
      {% if image %}
        <img class="lazyload w-full sm:h-[650px] lg:h-[950px] mt-[-2vw] object-cover aspect-square lg:aspect-3/4
          {% if imageOverlay %}brightness-70{% endif %}"
          src="{{ image.src | resize(32) }}"
          data-srcset="{{function('wp_get_attachment_image_srcset', image.id)}}"
          data-sizes="auto"
          alt="{{ image.alt|e }}"
          data-parallax>
      {% endif %}
      {% if image.caption %}
        <figcaption>{{ image.caption|e }}</figcaption>
      {% endif %}
    </figure>
    <div class="w-full sm:w-1/2 max-w-[800px] aspect-square lg:aspect-3/4 h-full flex flex-col gap-md justify-between
      p-sm xs:p-sm md:p-md lg:p-lg"
      style="background-color: {% if options.colorBackground %}{{ options.colorBackground }}{% else %}var(--brandColor){% endif %};">
      <div class="sm:h-1/2 text-white flex justify-start">
        {% for icons in icon %}
          {# <div class="icon flex justify-start h-[80px] w-[80px] lg:h-[120px] svg-h-full svg-w-full">{{ icons.icon }}</div> #}
           {% include 'Components/_Atoms/icon.twig' with {
              icon: icon[0],
              height: 'h-[80px] lg:h-[120px]',
              width: 'w-[80px] lg:w-[120px]',
            }%}
        {% endfor %}
      </div>
      <div class="h-1/2 pb-0 lg:pb-lg flex flex-col gap-md justify-end items-start fade-in move-up">
        <div class="wysiwyg text-white">{{ contentHtml|e('wp_kses_post') }}</div>
        {% if link %}
          <a href="{{ link.url }}" class="button button--outlineBlackWhite">{{ link.title }}</a>
        {% endif %}
      </div>
    </div>
  </div>
</flynt-component>
