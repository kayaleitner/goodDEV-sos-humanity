<flynt-component load:on="visible" name="BlockImageTextFull" class="" {{ options.theme ? 'data-theme="' ~ options.theme ~ '"' }}>
  <div class="md:h-[600px] lg:h-[900px] flex flex-col md:flex-row" {{ imagePosition ? 'data-image-position="' ~ imagePosition ~ '"' }}>
    <figure class="w-full md:w-1/2 overflow-hidden">
      {% if image %}
        <img class="lazyload w-full md:h-[650px] lg:h-[950px] mt-[-10px] object-cover aspect-square lg:aspect-3/4"
          src="{{ image.src | resize(32) }}"
          data-srcset="{{function('wp_get_attachment_image_srcset', image.id)}}"
          data-sizes="auto"
          alt="{{ image.alt|e }}"
          data-parallax
          {# data-rellax-speed="-2" #}
          {# data-rellax-percentage="0.54" #}
          >
      {% endif %}
      {% if image.caption %}
        <figcaption>{{ image.caption|e }}</figcaption>
      {% endif %}
    </figure>
    <div class="w-full md:w-1/2 h-full flex flex-col gap-md justify-between p-md md:p-sm lg:p-md" style="background: {{ bgcolor }};">
      <div class="md:h-1/2 text-white">
      {% for icons in icon %}
        <div>{{ icons.icon }}</div>
      {% endfor %}
      </div>
      <div class="h-1/2 pb-0 lg:pb-lg flex flex-col gap-md justify-end items-start fade-in move-up">
        <div class="text-white">{{ contentHtml|e('wp_kses_post') }}</div>
        <button class="w-fit px-sm py-xs cursor-pointer block relative z-2 border border-white rounded-full hover:bg-black hover:border-black text-white text-button transition-all" type="button" aria-label="Play Video"><a href="#">Read More</a></button>
      </div>
    </div>
  </div>
</flynt-component>
