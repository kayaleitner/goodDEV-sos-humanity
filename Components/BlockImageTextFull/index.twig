<flynt-component
  load:on="visible"
  name="BlockImageTextFull"
  class=""
  {{ options.theme ? 'data-theme="' ~ options.theme ~ '"' }}
  {{ options.navStyle ? 'data-navStyle="' ~ options.navStyle ~ '"' }}
>
  <div class="md:h-[600px] lg:h-[900px] flex flex-col md:flex-row" {{ imagePosition ? 'data-image-position="' ~ imagePosition ~ '"' }}  style="background-color: {% if options.colorBackground %}{{ options.colorBackground }}{% else %}var(--secondary){% endif %};">
    <figure class="w-full md:w-1/2 overflow-hidden">
      {% if image %}
        <img class="lazyload w-full md:h-[650px] lg:h-[950px] mt-[-2vw] object-cover aspect-square lg:aspect-3/4 {% if imageOverlay %}brightness-75{% endif %}"
          src="{{ image.src | resize(32) }}"
          data-srcset="{{function('wp_get_attachment_image_srcset', image.id)}}"
          data-sizes="auto"
          alt="{{ image.alt|e }}"
          data-parallax
          >
      {% endif %}
      {% if image.caption %}
        <figcaption>{{ image.caption|e }}</figcaption>
      {% endif %}
    </figure>
    <div class="w-full md:w-1/2 max-w-[800px] aspect-square lg:aspect-3/4 h-full flex flex-col gap-md justify-between p-md md:p-sm lg:p-lg" style="background-color: {% if options.colorBackground %}{{ options.colorBackground }}{% else %}var(--secondary){% endif %};">
      <div class="md:h-1/2 text-white">
      {% for icons in icon %}
        <div>{{ icons.icon }}</div>
      {% endfor %}
      </div>
      <div class="h-1/2 pb-0 lg:pb-lg flex flex-col gap-md justify-end items-start fade-in move-up">
        <div class="text-white">{{ contentHtml|e('wp_kses_post') }}</div>
        {% if link %}
          <a href="{{ readMoreButton.url }}" class="button button--outlineBlackWhite">{{ readMoreButton.title }}</a>
        {% endif %}
      </div>
    </div>
  </div>
</flynt-component>
