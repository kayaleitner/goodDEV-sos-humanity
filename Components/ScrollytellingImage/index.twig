<flynt-component class="" load:on="idle" name="ScrollytellingImage" {{ options.navStyle ? 'data-navStyle="' ~ options.navStyle ~ '"' }} 
  style="
    background-color: {% if options.colorBackground %}{{ options.colorBackground }}{% else %}var(--uiColor){% endif %};
    color: {% if options.colorText %}{{ options.colorText }}{% else %}var(--bgColor){% endif %};
  ">
  <div class="w-full mx-auto" id="scrollytellingImage">
    <div class="h-full relative" id="scrollytellingImage-inner">
      <div class="wrapper h-auto sm:h-screen w-full sm:absolute">
        {% if blockTitle %}
          <div class="w-full sm:absolute z-50">
            {% include 'Components/_Atoms/Titles/blockTitle.twig' with {
                blockTitleClasses: 'sm:w-full sm:max-w-screen-max mx-auto px-sm py-md sm:p-lg',
                blockTitle: blockTitle
              } 
            %}
          </div>
        {% endif %}
        {% for item in scrollytelling %}
          <section class="panelImage sm:absolute h-auto sm:h-screen w-full m-0 px-sm sm:p-0 {% if item.hideOnMobile %}hidden sm:block{% endif %}">
            {% if item.image %}
              <img 
                class="lazyload w-full h-full sm:absolute top-0 left-0 object-cover py-sm sm:p-0 border-b-4 border-dotted sm:border-0 {% if item.imageOverlay %}sm:brightness-50{% endif %}" 
                alt="{{ item.image.alt }}"
                style="border-color:{% if options.colorSecondary %}{{ options.colorSecondary }}{% else %}var(--bgColor){% endif %};" 
                src="{{ item.image.src | resize(32) }}" 
                data-srcset="{{function('wp_get_attachment_image_srcset', item.image.id)}}" 
                data-sizes="auto">
            {% endif %}
            {% if item.contentHtml %}
              <div class="wysiwyg sm:hidden row sm:max-w-[600px] mx-auto py-sm sm:pl-0 sm:pr-sm z-50">
                {{ item.contentHtml|e('wp_kses_post') }}
              </div>
            {% endif %}
          </section>
        {% endfor %}
      </div>
    </div>
    {% for item in scrollytelling %}
      <section class="relative hidden sm:block panel h-auto sm:h-screen w-full m-0 px-sm sm:p-0">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-0 sm:gap-lg sm:absolute top-0 left-0 w-full h-full justify-center items-center overflow-hidden">
          <div></div>
          {% if item.contentHtml %}
            <div class="wysiwyg row sm:max-w-[800px] ml-0 mr-auto py-sm sm:pl-0 sm:pr-lg z-50 fade-in move-up">
              {{ item.contentHtml|e('wp_kses_post') }}
            </div>
          {% endif %}
        </div>
      </section>
    {% endfor %}
  </div>
</flynt-component>
