<flynt-component
  load:on="idle"
  name="ScrollytellingImage"
  class=""
  style="background-color: {% if options.colorBackground %}{{ options.colorBackground }}{% else %}var(--white){% endif %};"
  {{ options.navStyle ? 'data-navStyle="' ~ options.navStyle ~ '"' }}
>
  
  <div class="w-full mx-auto" id="scrollytellingImage">
    <div id="scrollytellingImage-inner" class="h-full relative">
      <div class="wrapper h-auto md:h-screen w-full md:absolute">
        {% if blockTitle %}
          <div class="w-full md:absolute z-50">
            <h2 
            class="md:w-full md:max-w-screen-max mx-auto p-sm md:p-lg subtitle font-bold" 
            style="color:{% if options.colorText %}{{ options.colorText }}{% else %}var(--white){% endif %};">
              {{ blockTitle }}
            </h2>
          </div>
        {% endif %}
        {% for item in scrollytelling %}
          <section class="panel h-auto md:h-screen w-full m-0 px-sm md:p-0 {% if item.hideOnMobile %}hidden md:block{% endif %}">
            {% if item.image %}
              <img 
                class="w-full h-full md:absolute top-0 left-0 object-cover py-sm md:p-0 border-b-4 border-dotted border-black md:border-0 {% if item.imageOverlay %}brightness-75{% endif %}"
                src="{{ item.image.src }}"
                data-srcset="{{function('wp_get_attachment_image_srcset', item.image.id)}}"
                data-sizes="auto">
            {% endif %}
            {% if item.contentHtml %}
              <div class="md:hidden row md:max-w-[600px] mx-auto py-sm md:pl-0 md:pr-sm z-50">
                {{ item.contentHtml|e('wp_kses_post') }}
              </div>
            {% endif %}
          </section>
        {% endfor %}
      </div>
    </div>
    {% for item in scrollytelling %}
      <section class="relative hidden md:block panel h-auto md:h-screen w-full m-0 px-sm md:p-0">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-0 md:gap-lg md:absolute top-0 left-0 w-full h-full justify-center items-center">
          <div></div>
          {% if item.contentHtml %}
            <div class="row md:max-w-[800px] ml-0 mr-auto py-sm md:pl-0 md:pr-lg z-50 fade-in move-up">
              {{ item.contentHtml|e('wp_kses_post') }}
            </div>
          {% endif %}
        </div>
      </section>
    {% endfor %}
  </div>
</flynt-component>
