{% if posts|length > 0 %}
  <flynt-component class="" data-type="listing" load:on="visible" name="ListingProjects">
    <div class="w-full mx-auto max-w-screen-max p-sm md:p-md lg:p-lg">
      {% if blockTitle %}
        <div class="w-full mx-auto max-w-screen-max pb-sm md:pb-md lg:pb-lg flex flex-row justify-between items-center content-center">
          <h2 class="font-bold subtitle !leading-subtitle block-title">{{ blockTitle }}</h2>
          <a href="{{ labels.allPostsLink.url }}" class="font-bold underline hover:no-underline caption">{{ labels.allPosts }}</a>
        </div>
      {% endif %}
      <ul class="w-full mx-auto grid gap-sm lg:gap-md xs:grid-cols-2 sm:grid-cols-3 xl:grid-cols-4" id="projects">
        {% for post in posts %}
          {% include 'Partials/_post.twig' with {post: post} %}
        {% endfor %}
      </ul>
      {% if posts|length >= 4 %}
        <div class="mt-md flex justify-center items-center align-middle">
          <a class="button button--outlineBlack" data-action="loadMore" id="loadMore">Load More</a>
        </div>
      {% endif %}
    </div>
  </flynt-component>
{% endif %}