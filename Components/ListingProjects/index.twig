{% if posts|length > 0 %}
  <flynt-component load:on="visible" name="ListingProjects" data-type="listing" class="">
    <div class="max-w-screen-max w-full mx-auto p-sm md:p-md lg:p-lg">
      {% if blockTitle %}
        <div class="max-w-screen-max w-full mx-auto pb-sm md:pb-md lg:pb-lg flex flex-row justify-between items-center content-center">
          <h2 class="subtitle block-title font-bold">{{ blockTitle }}</h2>
          <a href="{{ labels.allPostsLink.url }}" class="underline hover:no-underline caption font-bold">{{ labels.allPosts }}</a>
        </div>
      {% endif %}
      <ul id="projects" class="
          w-full
          mx-auto
          grid xs:grid-cols-2 sm:grid-cols-3 xl:grid-cols-4
          gap-sm lg:gap-md
        ">
        {% for post in posts %}
          {% include 'Partials/_post.twig' with {post: post} %}
        {% endfor %}
      </ul>

      {% if posts|length >= 4 %}
        <div class="mt-md flex justify-center align-middle items-center">
          <a class="button button--outlineBlack" id="loadMore" data-action="loadMore">Load More</a>
        </div>
      {% endif %}

    </div>
  </flynt-component>
{% endif %}
