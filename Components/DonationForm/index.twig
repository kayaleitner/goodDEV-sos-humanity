{% set gridClasses = 'grid grid-cols-1 sm:grid-cols-2 gap-8' %}
<flynt-component
  class="flyntComponent {{ options.theme }} block"
  is="flynt-donation-form"
  name="DonationForm"
>
  
  {#    hash: de  y3fkgajfly2vnohz  it: pr31cc1oi4mxm9y4 en: 9qe7gtlxtyswnhld
{#    hash: agh  r8lics3y58gk40ib
  #}
  <form id="fbx-donation-form" data-fbx-form-hash="{{ hash | default('r8lics3y58gk40ib') }}"
        class="donationForm">
    
    <div class="panel">
      {% include 'Partials/_panelHeader.twig' with { panel_title: labelPanelInterval } only %}
      {% include 'Partials/_intervalBlock.twig' %}
      {% include 'Partials/_amountBlock.twig' %}
    </div>
    <h2>{{ amountPlaceholder }}</h2>
    
    {# Persönliche Daten #}
    <div class="panel">
      {% include 'Partials/_panelHeader.twig' with { panel_title: labelContactPanel } only %}
      {% include 'Partials/_contactBlock.twig' with { gridClasses } %}
      {# Adresse (versteckt, wenn weder Firma noch wants_receipt) #}
      {% include 'Partials/_addressBlock.twig' %}
    </div>
    
    {# payment-methods #}
    <div class="panel">
      {% include 'Partials/_panelHeader.twig' with { panel_title: labelPaymentMethodPanel } only %}
      <div class="payment-methods mb-6"></div>
      {% include 'Partials/_sepaDebitFieldsBlock.twig' with { gridClasses } %}
      {% include 'Partials/_creditCardFieldsBlock.twig' with { gridClasses } %}
      {% include 'Partials/_creditCardHiddenFieldsBlock.twig' with { gridClasses } %}
    </div>
    <div class="mt-8 text-center">
      <button id="donation-submit-btn" type="button"
              class="button button--small">{{ options.buttonText | default( fn('pll__','Jetzt spenden', 'flynt')) }}</button>
    </div>
    {# Global FRBox error message #}
    <div style="display: none" id="#errorMsg" class="error-text text-center">Es sind leider Fehler aufgetreten! Bitte überprüfe deine Angaben.</div>
    {# hidden fields e.g. amount, succesUrl, custom fields #}
    <div id="hidden-fields" class="hidden">
      {% include 'Partials/_donationCustomFields.twig' %}
      <input checked="checked" type="checkbox" id="payment_wants_newsletter" name="payment[wants_newsletter]">
    </div>
  </form>
</flynt-component>