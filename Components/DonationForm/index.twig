{% set panelClasses = 'p-4 bg-white rounded-sm shadow-md mb-6' %}
<flynt-component
  class="flyntComponent {{ options.theme }} block"
  is="flynt-donation-form"
  name="DonationForm"
>
  
  {#    hash: de  y3fkgajfly2vnohz  it: pr31cc1oi4mxm9y4 en: 9qe7gtlxtyswnhld
{#    hash: agh  r8lics3y58gk40ib
  #}
  {% set currentLang = function('function_exists', 'pll_current_language') ? function('pll_current_language') : null %}
  
  {% set selectedHash = null %}
  {% if options.hashes is iterable %}
    {{ dump(currentLang) }}
    {% set pref = currentLang ? currentLang|upper : null %}
    {% for item in options.hashes %}
      {% if pref and item.lang == pref %}
        {% set selectedHash = item.hash %}
      {% endif %}
    {% endfor %}
  {% endif %}
  {% if not selectedHash and options.hashes is iterable and options.hashes|length %}
    {% set selectedHash = options.hashes[0].hash %}
  {% endif %}
  <form id="fbx-donation-form" data-fbx-form-hash="{{ hash | default('9qe7gtlxtyswnhld') }}"
        class="donation-form">
    
    {# Intervall #}
    <div class="panel {{ panelClasses }}">
      <div id="interval-section" class="interval-section mb-6">
        <div class="flex flex-wrap gap-4"></div>
      </div>
      
      {# Betragsvorschläge + freie Eingabe #}
      <div id="amount-section" class="mb-6">
        <div class="flex flex-wrap gap-3 mb-3"></div>
        <div>
          <label class="block text-sm font-medium mb-1">Eigener Betrag</label>
          <input type="number" step="1" min="1" class="w-full md:w-64 border rounded px-3 py-2" name="amount_custom"
                 placeholder="{{ options.amountPlaceholder|default('Betrag eingeben') }}">
        </div>
      </div>
    </div>
    
    {# Persönliche Daten #}
    <div class="panel {{ panelClasses }}">
    <div id="person-section" class="space-y-6">
      <div id="row-salutation" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
      <div id="row-name" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
      <div id="row-contact" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
      <div id="row-wants-receipt" class="grid grid-cols-1 gap-4"></div>
      <div id="row-wants-newsletter" class="grid grid-cols-1 gap-4"></div>
    </div>
    
    
    {# Adresse (versteckt, wenn weder Firma noch wants_receipt) #}
    <div id="address-section" class="space-y-4 mt-6 hidden">
      <div id="row-address-1" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
      <div id="row-address-2" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
    </div>
    </div>
    
    {# Zahlmethoden #}
    <div class="panel {{ panelClasses }}">
    <div id="payment-section" class="mt-8 space-y-4">
      <div id="payment-methods" class="space-y-2"></div>
      <div id="payment-fields" class="space-y-4"></div>
    </div>
    </div>
    
    {# Versteckte Felder #}
    <div id="hidden-fields" class="hidden"></div>
    
    <div class="mt-8 text-center">
      <button type="submit" class="button button--small">{{ options.buttonText | default('Jetzt spenden') }}</button>
    </div>
  
  </form>
</flynt-component>