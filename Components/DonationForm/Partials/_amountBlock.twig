<div class="amount-block">
  {% set current_interval = interval|default('0') %}
  {% set active_intervals = active_intervals|default(['0', '1']) %}
  {% set amounts_mapping = {
    '0': amounts_one_time,
    '1': amounts_monthly,
    '3': amounts_quarterly,
    '6': amounts_half_yearly,
    '12': amounts_yearly
  } %}
  
  <!-- Betragsvorschläge -->
  <div class="amount-suggestions w-full">
    {% for key, amounts in amounts_mapping %}
      {% if key in active_intervals %}
        {% set is_active = current_interval == key %}
        <div class="amount-group-wrapper {{ is_active ? 'active' : '' }}" data-interval="{{ key }}">
          {% for amount in amounts %}
            {% set btn_id = 'amount_' ~ key ~ '_' ~ loop.index %}
            <div class="amount-option">
              <input class="amount-radio" id="{{ btn_id }}" name="donation_amount_{{ key }}" type="radio"
                     value="{{ amount.value }}" {{ amount.default ? 'checked' : '' }}
                     data-interval="{{ key }}">
              <label class="amount-label" for="{{ btn_id }}">{{ amount.value|number_format(0, ',', '.') }}€</label>
            </div>
          {% endfor %}
          {% if show_custom_amount is not defined or show_custom_amount %}
            <!-- Benutzerdefinierter Betrag -->
            <div class="amount-option custom-amount global-custom-amount">
              <input autocomplete="off" min="{{ minAmount|default(3) }}" max="{{ maxAmount|default(50000) }}" step="0.01"
                     class="amount-input" name="donation_custom_amount_{{ key }}" type="number" value=""
                     inputmode="numeric" placeholder="{{ customAmountPlaceholder|default('Eigener Betrag') }}">
              <span class="currency-suffix">€</span>
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
  
  <!-- Verstecktes Feld für den finalen Betrag -->
  <div id="payment_amount_wrapper" class="relative">
    <input type="text" name="payment[amount]" id="payment_amount">
    <div id="payment_amount_error" class="error error-text text-center"></div>
  </div>
</div>