

{#<div data-default-interval="{{ interval|default('0') }}"#}
{#     class="donationForm__interval mb-6 donationForm__radio"></div>#}

<div class="amount-block">
  {% set current_interval = interval|default('0') %}
  <div class="amount-suggestions w-full">
    {% for item in amounts %}
      {% set interval_key = item.interval_type ? '1' : '0' %}
      {% set is_active = current_interval == interval_key %}
      <div class="amount-group-wrapper {{ is_active ? 'active' : '' }}" data-interval="{{ interval_key }}">
        {% for key, amount in item.amount_options %}
          {% set btn_id = 'amount_'~ interval_key ~ '_' ~ loop.index %}
          <div class="amount-option">
            <input class="amount-radio" id="{{ btn_id }}" name="donation_amount_{{ interval_key }}" type="radio"
                   value="{{ amount.value }}" {{ amount.default ? 'checked' : '' }}
                   data-interval="{{ interval_key }}">
            <label class="amount-label" for="{{ btn_id }}">{{ amount.value }}€</label>
          </div>
          {% if loop.index == item.amount_options | length %}
          <div class="amount-option custom-amount global-custom-amount">
            <input autocomplete="off" min="3" max="50000" class="amount-input" name="donation_custom_amount_{{ interval_key }}"
                   type="number" value="" inputmode="decimal"
                   placeholder="{{ customAmountPlaceholder }}">
            <span class="currency-suffix">€</span>
          </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endfor %}
  
  </div>
</div>
<div class="error-wrapper text-center">
  <span id="amount-error-text" class="error-text"></span>
</div>
<div id="payment_amount_wrapper" class="hidden"><label for="payment_amount">Betrag</label><input type="text" name="payment[amount]" id="payment_amount"><div id="payment_amount_error" class="error"></div></div>