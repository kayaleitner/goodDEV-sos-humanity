<ul class="menu menu--level-{{ level }} flex flex-row gap-sm">
  {% for item in items %}
    <li class="{{ item.classes | join(' ') }} body-2 !text-white hover:text-grey">
      <a class="menu-link" href="{{ item.link }}"{% if item.target %} target="{{ item.target }}"{% endif %}>{{ item.title }}</a>
      {% if item.children and level + 1 <= maxLevel %}
        {% include 'Partials/_menu.twig' with { 'items': item.children, 'level': level + 1, 'maxLevel': maxLevel } only %}
      {% endif %}
    </li>
  {% endfor %}
</ul>
