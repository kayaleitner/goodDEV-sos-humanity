<flynt-component load:on="visible" name="BlockProjectBox" class="w-full md:w-full lg:max-w-[420px] flex flex-col md:flex-row lg:flex-col gap-lg">
  {# Box #}
  <div class="w-full md:w-1/2 lg:w-full flex flex-col md:flex-row lg:flex-col gap-lg items-center">
    <div class="w-full border border-black p-sm flex flex-col">
      <div class="py-sm first:pt-0 flex flex-row gap-lg justify-between items-center border-b border-black">
        <span class="">Commission date</span>
        <span class="h5 text-right">Feb 2021</span>
      </div>
      <div class="py-sm flex flex-row gap-lg justify-between items-center border-b border-black">
        <span class="">Size of installation</span>
        <span class="h5 text-right">28,250 kW</span>
      </div>
      <div class="py-sm flex flex-row gap-lg justify-between items-center border-b border-black">
        <span class="">Mounting type</span>
        <span class="h5 text-right">Hybrid system</span>
      </div>
      <div class="py-sm flex flex-row gap-lg justify-between items-center border-b border-black">
        <span class="">Agreement</span>
        <span class="h5 text-right">15-year</span>
      </div>
      <div class="py-sm last:pb-0 flex flex-row gap-lg justify-between items-center border-b border-black last:border-b-0">
        <span class="">Partners</span>
        <span class="h5 text-right">Ghana</span>
      </div>
    </div>
  </div>
  {# Map #}
  <div class="relative md:w-1/2 lg:w-full">
      <div data-ref="mapWrapper" class="h-auto aspect-video relative" id="dottedMap"></div>
      <div class="pin bg-cbegreen rounded-full w-lg h-lg absolute"
        data-ref="pin"
        data-latitude="{{ post.latitude }}" 
        data-longitude="{{ post.longitude }}"></div>
    </div>
</flynt-component>
