<flynt-component load:on="idle" name="HeroIllustration" class="" style="background-color: var(--secondary);">
  <div class="max-w-screen-max mx-auto px-sm py-sm md:px-lg md:py-lg">
    {% if blockTitle %}
    <div class="h4 text-white pb-xl z-50">{{ blockTitle }}</div>
    {% endif %}
    <div class="max-w-screen-max mx-auto h-full flex flex-col gap-xl md:flex-row items-center md:items-start justify-around p-lg md:py-xl">
    {% for item in illustrations %}
      <div class="item w-full md:w-1/3 max-w-[400px] flex flex-col gap-md md:gap-lg justify-center items-center">
          {% if item.illustration %}
            <figure class="figure">
              <img class="figure-image lazyload max-w-[200px] my-auto max-h-40 md:max-h-max"
                src="{{ item.illustration.src | resize(32) }}"
                data-srcset="{{function('wp_get_attachment_image_srcset', item.illustration.id)}}"
                data-sizes="auto">
            </figure>
          {% endif %}
          {% if item.contentHtml %}
            <div class="text-white">
              {{ item.contentHtml|e('wp_kses_post') }}
            </div>
          {% endif %}
      </div>
    {% endfor %}
    </div>
  </div>
</flynt-component>
