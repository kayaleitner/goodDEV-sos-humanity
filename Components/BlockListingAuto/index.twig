{% set componentOptions = {
    name: 'BlockListingAuto',
    loadOn: 'visible',
} %}

{% set content %}
  <div class="container">
    <div class="grid">
    {% if (blockTitle or viewAllLink or filters) %}
      <div class="w-full mx-auto p-sm md:p-md lg:p-lg flex flex-col justify-between align-bottom items-end gap-md border-1">
        {% if blockTitle or viewAllLink %}
          <div class="w-full mx-auto flex flex-col sm:flex-row justify-between items-baseline content-center">
            <div class="font-titleSmall pb-sm sm:pb-0">{{ blockTitle }}</div>
            <a href="{{ viewAllLink.url }}" class="font-bodyLarge font-bold font-condensed">{{ viewAllLink.title }}</a>
          </div>
        {% endif %}
        {% if filters %}
          <div class="filters w-full flex flex-col md:flex-row gap-sm" x-data="{filters: [] }">
            {% for index, flexFilter in filters %}
              {% include 'Components/_Atoms/Other/filters.twig' 
                with {
                  filterName: flexFilter.name,
                  filterLabel: flexFilter.label,
                  filterTerms: flexFilter.terms
                }
              %}
            {% endfor %}
          </div>
        {% endif %}
      </div>
    {% endif %}
    <ul data-refs="listing"
      class="w-full mx-auto grid grid-cols-1 xs:grid-cols-2 md:grid-cols-3"
      data-post-types="{{post_types|json_encode|e}}"
      data-orderby='{{ orderby }}'
      data-order='{{ order }}'
      data-max-posts='{{ maxPosts }}'
      data-labels='{{ labels|json_encode()|e }}'
      data-query='{{ tax_query|json_encode()|e }}'>
      {% include 'Partials/_items.twig' with {posts: posts, 'labels': labels } %}
    </ul>
    {% if (show_load_more and found_posts > posts|length ) %}
      <div class="w-full flex justify-center align-center">
        <a class="btn btn-primary hover:cursor-pointer text-buttonSmall font-bold my-8" data-refs="loadMore">
          View More
        </a>
      </div>
    {% endif %}
    </div>
  </div>
{% endset %}

{% if posts|length > 0 %}
  {% include 'Components/_Containers/FlyntComponent.twig' with {
    content: content,
    componentOptions: componentOptions
  } %}
{% else %}
  {% include 'Components/_Atoms/Other/noResults.twig' %}
{% endif %}
