<flynt-component
  class="flyntComponent componentSpacing donation-barometer"
  is="flynt-donation-barometer"
  data-goal="{{ goal_amount }}"
  data-current="{{ current_amount }}"
  data-donors="{{ donor_count }}"
  data-display-type="{{ display_type }}"
  name="DonationBarometer"
  style="--themeBrand_colorBackground: {{ options.colorBrandBackground ?? '#fff' }}; --themeBrand_colorText: {{ options.colorBrandText ?? '#1c2445' }};"
>
  {% set bgColor = options.colorBrandBackground ?? '#fff' %}
  {% set isDarkBg = (bgColor|hex_to_luminance < 0.5) %}
  {% set shipClass = isDarkBg ? 'donation-barometer__ship--light' : 'donation-barometer__ship--dark' %}
  {% set textShadowColor = isDarkBg ? bgColor : 'transparent' %}
  <div class="donation-barometer__panel" style="--text-shadow-color: {{ textShadowColor }};">
    {% if title %}
      <h3 class="donation-barometer__title">{{ title }}</h3>
    {% endif %}
    
    {% if barometer_text %}
    <div
      class="donation-barometer__text">{{ barometer_text | replace({'{current_amount}': current_amount|number_format(0, '.', '.'), '{donor_count}': donor_count|number_format(0, '.', '.'), '{goal_amount}': goal_amount|number_format(0, '.', '.') }) }}</div>
    {% endif %}
    
    {% if barometer_title_current %}
      <div class="donation-barometer__current">
        <div class="donation-barometer__current--title">{{ barometer_title_current }}</div>
        {% if display_type == 'count' %}
          <span class="donation-barometer__current--amount">0</span>
        {% else %}
          <span class="donation-barometer__current--amount">0</span><span class="euro"> Euro</span>
        {% endif %}
      </div>
    {% endif %}
    
    
    <div class="donation-barometer__bar-container">
      <div class="donation-barometer__fill" style="background: {{ options.colorBrandText ?? '#2EB7EC' }};"></div>
      <div class="donation-barometer__waves"></div>
      <div class="donation-barometer__ship {{ shipClass }}" aria-hidden="true"></div>
    </div>
    
    <div class="donation-barometer__goal-note" aria-label="Goal">
      {% if display_type == 'count' %}
        {{ barometer_text_goal_amount }} {{ goal_amount|number_format(0, '.', '.') }}
      {% else %}
        {{ barometer_text_goal_amount }} {{ goal_amount|number_format(0, '.', '.') }} Euro
      {% endif %}
    </div>
  </div>
</flynt-component>
