<flynt-component
  load:on="idle" name="BlockPulloutQuote"
  class="w-full py-lg"
  {{ options.navStyle ? 'data-navStyle="' ~ options.navStyle ~ '"' }}
>
  <div class="flex flex-col">
    {% for item in quotes %}
      <div class="item w-full py-md flex flex-col md:flex-row gap-md md:gap-md justify-center items-start fade-in move-up {% if item.borderTop %} border-t-[4px] border-dotted border-cbegreen{% endif %}">
        {% if item.contentHtml %}
          <div class="w-full md:w-2/3">
            {{ item.contentHtml|e('wp_kses_post') }}
          </div>
        {% endif %}
        {% if item.image %}
          <figure class="figure w-full md:w-1/3">
            <img class="figure-image"
              src="{{ item.image.src }}"
              data-srcset="{{function('wp_get_attachment_image_srcset', item.image.id)}}"
              data-sizes="auto">
            {% if item.imageCaptionHtml %}
              <figcaption class="h6 mt-sm">{{ item.imageCaptionHtml|e('wp_kses_post') }}</figcaption>
            {% endif %}
          </figure>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</flynt-component>
