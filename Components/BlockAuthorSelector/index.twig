{% if posts|length > 0 %}
  <flynt-component load:on="visible" name="BlockAuthorSelector" data-type="listing" class="">
    <div class="">
      <ul class="max-w-screen-max mx-auto px-sm lg:px-lg flex flex-col lg:flex-row gap-sm lg:gap-md justify-between">
        {% for post in posts %}
          <div class="w-full pb-xs">
            <div class="w-full py-xs flex flex-row gap-sm border-t border-lightgrey">
              <img
                class="aspect-square object-cover w-1/3 grayscale"
                src="{{ post.thumbnail.src }}"
                data-srcset="{{function('wp_get_attachment_image_srcset', post.thumbnail.id)}}"
                data-sizes="auto">
              <div class="h6 w-2/3 flex flex-col">
                <div class="font-bold">{{ post.title }}</div>
                <div>Position</div>
              </div>
            </div>
            <div class="flex justify-end items-center">
              <a href="{{ post.link }}" class="button button--arrow" target="_blank" rel="noreferrer noopener"></a>
            </div>
          </div>
        {% endfor %}
      </ul>
    </div>
  </flynt-component>
{% endif %}
