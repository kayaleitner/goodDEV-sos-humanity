<flynt-component 
  load:on="visible" 
  name="BlockTeamHeader" 
  class="w-full mx-auto flex flex-col md:flex-row gap-lg" 
  data-navStyle="light-blur"
  >
  <section class="w-full md:w-2/3 flex flex-col gap-md">
    <div class="w-full flex flex-col">
      <h1 class="h2 mb-0">{{ post.title }}</h1>
      <div class="">{{ post.position }}</div>
    </div>
    {% if post.bio %}
      <div>{{ post.bio }}</div>
    {% endif %}
    <div class="social lg:w-1/2 flex flex-row gap-sm items-start justify-start">
      {% for item in post.socials %}
        <a class="no-underline" href="{{ item.url }}" target="_blank" aria-label="{{ item.platform.label }}">
          {{ item.platform.label }}
        </a>
      {% endfor %}
      </ul>
    </div>
    <div class="flex flex-row lg:flex-col gap-sm justify-start items-start h-full">
      <a class="link button button--outlineBlack" href="{{ labels.backButtonLink }}">{{ labels.backButton }}</a>
    </div>
  </section>
  <section class="w-full md:w-1/3 flex flex-col gap-lg">
    {% if post.thumbnail %}
      <div class="featuredImage w-full">
        <img class="figure-image lazyload h-full w-full object-cover"
          src="{{ post.thumbnail.src | resize(32) }}"
          data-srcset="{{function('wp_get_attachment_image_srcset', post.thumbnail.id)}}"
          data-sizes="auto">
      </div>
    {% endif %}
    <div class="facts w-full flex flex-col md:flex-row lg:flex-col gap-lg items-center">
      <div class="w-full border border-black p-sm flex flex-col">
        <div class="py-sm first:pt-0 flex flex-row gap-lg justify-between items-center border-b border-black">
          <span class="h6">Location</span>
          <span class="h5 text-right">Taxonomy</span>
        </div>
        <div class="py-sm flex flex-row gap-lg justify-between items-center border-b border-black">
          <span class="h6">Team</span>
          <span class="h5 text-right">---</span>
        </div>
        <div class="py-sm flex flex-row gap-lg justify-between items-center border-b border-black">
          <span class="h6">Expertise</span>
          <span class="h5 text-right">Tags</span>
        </div>
        <div class="py-sm flex flex-row gap-lg justify-between items-center border-b border-black">
          <span class="h6"></span>
          <span class="h5 text-right">---</span>
        </div>
      </div>
      {# <div class="factsflex flex-col">
        {% for item in post.facts %}
          <div class="py-sm flex flex-row gap-lg justify-between items-center border-b border-black">{{ item.factTextarea }}</div>
        {% endfor %}
        {% if post.download %}
          <div class="pt-sm">
            <a class="download button button--outlineBlack" href="{{ post.download.url|e }}" alt="{{ post.download.alt|e }}" target="_blank" rel="noreferrer noopener">
              {{ post.downloadLinkLabel|e }}
            </a>
          </div>
        {% endif %}
      </div> #}
    </div>
  </section>
</flynt-component>
