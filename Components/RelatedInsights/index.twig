{% if relatedInsights|length > 0 %}
  <flynt-component load:on="visible" name="RelatedInsights" data-type="listing" class="">
    <div class="outer max-w-screen-max w-full mx-auto p-sm md:p-md lg:p-lg">
      {% if blockTitle %}
        <div class="w-full mx-auto pb-sm sm:pb-lg flex flex-row justify-between items-center content-center">
          <h2 class="subtitle !leading-subtitle block-title font-bold">{{ blockTitle }}</h2>
          <a href="{{ labels.allPostsLink.url }}" class="underline hover:no-underline caption font-bold">{{ labels.allPosts }}</a>
        </div>
      {% endif %}
      <ul
        class="
          w-full
          mx-auto
          grid xs:grid-cols-2 lg:grid-cols-3 
          gap-0 xs:gap-md
        "
      > 
        {% for post in relatedInsights %}
          {% include 'Components/_Atoms/Cards/post.twig' with { 'post': post, 'labels': labels } only %}
        {% endfor %}
      </ul>
    </div>
  </flynt-component>
{% endif %}
