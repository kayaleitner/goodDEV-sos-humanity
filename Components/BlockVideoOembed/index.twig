{% set componentOptions = {
    name: 'BlockVideoOembed',
    loadOn: 'visible',
} %}

{% set content %}
  <div class="">
    <div class="video">
      {% include 'Partials/_figure.twig' ignore missing with {image: posterImage} only %}
      <div data-ref="videoPlayer" class="video-player">
        {# {{ oembed|raw }} #}
        {{ oembed }}
        <div class="video-loader"></div>
        <div class="video-content absolute w-full h-full flex flex-col justify-center align-middle items-center">
          <div class="max-w-screen-md mx-auto flex flex-col justify-center align-middle items-center gap-md">
            <div class="wysiwyg video-title titleLarge text-bgColor text-center">{{ contentHtml|e('wp_kses_post') }}</div>
            <button data-ref="playButton" class="video-playButton button button--outlineBlackWhite" type="button" aria-label="{{ labels.playButtonText }}">{{ labels.playButtonText }}</button>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endset %}

{% include 'Components/_Containers/FlyntComponent.twig' with {
    content: content,
    componentOptions: componentOptions
} %}
