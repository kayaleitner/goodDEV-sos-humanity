<figure data-ref="posterImage" class="figure aspect-video me-0">
  <img class="figure-image lazyload h-[100vw] lg:h-full w-full object-cover"
    src="{{ image.src | resize(32) }}"
    data-srcset="{{ function('wp_get_attachment_image_srcset', image.id) }}"
    data-sizes="auto"
    alt="{{ image.alt|e }}">
</figure>
