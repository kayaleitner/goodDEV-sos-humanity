<flynt-component 
  load:on="visible" 
  name="BlockProjectHeader" 
  class="w-full mx-auto flex flex-col md:flex-row justify-between items-center" 
  style="background: var(--secondary);"
  data-navStyle="dark-clear">
  <div class="w-full mx-auto flex flex-col md:flex-row justify-between items-center"
    data-ref="pin"
    data-latitude="{{ post.latitude }}" 
    data-longitude="{{ post.longitude }}">
    <div class="w-full md:w-1/2 grow hidden md:block"></div>
    {% if post.thumbnail %}
      <div class="w-full md:w-1/2 md:min-h-[720px] grow aspect-square sm:aspect-2/1 overflow-hidden">
        <img class="lazyload w-full h-full object-cover aspect-2/1 brightness-75"
          src="{{ post.thumbnail.src | resize(32) }}"
          data-srcset="{{function('wp_get_attachment_image_srcset', post.thumbnail.id)}}"
          data-sizes="auto">
      </div>
      {% else %}
      <div class="w-full md:w-1/2 md:min-h-[720px] grow aspect-square sm:aspect-2/1 overflow-hidden">
        <div class="w-full h-full relative">
          <div class="titleSmall font-bold text-[orange] absolute top-0 left-0 h-full w-full flex justify-center items-center">Please set a featured image.</div>
        </div>
      </div>
    {% endif %}
  </div>
  <div class="w-full max-w-screen-max mx-auto aspect-square sm:aspect-2/1 md:aspect-auto flex flex-row justify-center items-center md:absolute md:left-1/2 md:-translate-x-1/2">
    <div class="w-full md:w-1/2 h-full p-sm sm:p-md lg:p-lg grow text-white" style="background: var(--secondary);">
      <h1 class="titleSmall font-bold mb-md">{{ post.title }}</h1>
      {% for term in post.terms('country')  %}
        <div class="subtitle">{{ term }}</div>
      {% endfor %}
    </div>
    <div class="w-full md:w-1/2 grow hidden md:block"></div>
  </div>
</flynt-component>
