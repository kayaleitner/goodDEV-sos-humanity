<flynt-component 
  load:on="visible" 
  name="BlockPeopleHeader" 
  class="w-full mx-auto py-sm lg:py-lg flex flex-col-reverse sm:flex-row gap-lg" 
  data-navStyle="light-blur"
  >
  <section class="w-full sm:w-2/3 flex flex-col gap-md">
    <div class="w-full flex flex-col">
      <h1 class="text-titleSmallMobile lg:text-titleSmall mb-sm">{{ post.title }}</h1>
      <div class="text-bodyMobile lg:text-body">{{ post.position }}</div>
    </div>
    {% if post.bio %}
      <div>{{ post.bio }}</div>
    {% endif %}
    <div class="social lg:w-1/2 flex flex-row gap-sm items-start justify-start">
      {% for item in post.socials %}
        <a class="no-underline text-subtitleMobile lg:text-subtitle" href="{{ item.url }}" target="_blank" aria-label="{{ item.platform.label }}">
          <span data-icon="{{ item.platform.label|lower }}-outline"></span>
        </a>
      {% endfor %}
      </ul>
    </div>
    <div class="flex flex-row lg:flex-col gap-sm justify-start items-start h-full">
      <a class="link button button--outlineBlack" href="{{ labels.backButtonLink.url }}">{{ labels.backButton }}</a>
    </div>
  </section>
  <section class="w-full sm:w-1/3 flex flex-col gap-lg">
    {% if post.thumbnail %}
      <div class="featuredImage w-full">
        <img class="figure-image lazyload h-full w-full object-cover"
          src="{{ post.thumbnail.src | resize(32) }}"
          data-srcset="{{function('wp_get_attachment_image_srcset', post.thumbnail.id)}}"
          data-sizes="auto">
      </div>
      {% else %}
      <div class="w-full sm:w-1/2 grow aspect-square overflow-hidden">
        <div class="w-full h-full relative">
          <div class="titleSmall font-bold text-[orange] absolute top-0 left-0 h-full w-full flex justify-center items-center">Please set a featured image.</div>
        </div>
      </div>
    {% endif %}
    <div class="facts w-full flex flex-col sm:flex-row lg:flex-col gap-lg items-center">
      <div class="w-full border border-black p-sm flex flex-col">
        <div class="py-sm first:pt-0 flex flex-row gap-lg justify-between items-center border-b border-black">
          <span class="caption">Location</span>
          <span class="caption text-right">
          {% for term in post.terms('country')  %}
            <div class="body">{{ term }}</div>
          {% endfor %}
          </span>
        </div>
        {# <div class="py-sm flex flex-row gap-lg justify-between items-center border-b border-black">
          <span class="caption">Team</span>
          <span class="caption text-right">---</span>
        </div> #}
        <div class="pt-sm flex flex-row gap-lg justify-between items-center">
          <span class="caption">Division</span>
          <span class="caption text-right">
          {% for term in post.terms('division')  %}
            <div class="body">{{ term }}</div>
          {% endfor %}
          </span>
        </div>
        {# <div class="py-sm flex flex-row gap-lg justify-between items-center border-b border-black">
          <span class="caption"></span>
          <span class="caption text-right">---</span>
        </div> #}
      </div>
      {# <div class="factsflex flex-col">
        {% for item in post.facts %}
          <div class="py-sm flex flex-row gap-lg justify-between items-center border-b border-black">{{ item.factTextarea }}</div>
        {% endfor %}
        {% if post.download %}
          <div class="pt-sm">
            <a class="download button button--outlineBlack" href="{{ post.download.url|e }}" alt="{{ post.download.alt|e }}" target="_blank" rel="noreferrer noopener">
              {{ post.downloadLinkLabel|e }}
            </a>
          </div>
        {% endif %}
      </div> #}
    </div>
  </section>
</flynt-component>
