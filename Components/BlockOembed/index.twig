{% set content %}
  <div data-ref="embed" data-videomode="{{ videoMode }}" class="relative">
    
    {{ oembed|raw }}

    {% if videoMode == 'on' %}
    {# {{ oembed }} #}
    <div data-ref="poster" class="video-content absolute top-0 left-0 w-full h-full flex flex-col justify-center align-middle items-center bg-brandColor">
      {% if posterImage.src %}
        <img
          class="image lazyload anim-fade-in object-cover w-full h-full"
          src="{{ posterImage.src | resize(32) }}"
          width="{{ 768 }}"
          height="{{ (768 / posterImage.aspect)|round }}"
          data-srcset="{{function('wp_get_attachment_image_srcset', posterImage.id)}}"
          data-sizes="auto"
          alt="{{ posterImage.alt|e }}"
        />
      {% endif %}
      <button
        data-ref="playButton"
        class="video-playButton button button--accent aspect-square !p-sm !absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"
        type="button" aria-label="{{ labels.playButtonText }}"
      >
      <div class="playButton relative w-[40px] h-[40px]">
        <span data-ref="playIcon" class="absolute top-0 left-[8px] w-0 h-0 border-t-[20px] border-t-transparent border-l-[30px] border-l-white border-b-[20px] border-b-transparent"></span>
      </div>
      <div
        role="status"
        data-ref="loadingSpinner"
        class="absolute loading-spinner w-[40px] h-[40px] rounded-full border-white border-4 border-t-0 border-r-0 animate-spin"
        style="opacity: 0;"
      >
        <span class="sr-only">Loading...</span>
      </div>
      </button>
    </div>
    {% endif %}
  </div>
{% endset %}

<flynt-component
  load:on="visible"
  name="BlockOembed"
  {{ options.navStyle ? 'data-navStyle="' ~ options.navStyle ~ '"' }}>
  <div class="container mx-auto grid grid-cols-6 md:grid-cols-12 gap-sm">
    <div class="
        col-start-1 xs:col-start-2 md:col-start-1 wide:col-start-2
        col-span-6 xs:col-span-4
        wysiwyg
      ">
    {{ contentHtml|e('wp_kses_post') }}
    </div>
    <div class="
        col-start-1 md:col-start-6
        col-span-7
        wysiwyg
      ">

      {% if function('shortcode_exists', 'borlabs-cookie') %}
        {% apply shortcodes %}
        [borlabs-cookie type="content-blocker" title="external"]
          {{ content }}
        [/borlabs-cookie]
        {% endapply %}
      {% else %}
        {{ content }}
      {% endif %}

    </div>
  </div>
</flynt-component>
