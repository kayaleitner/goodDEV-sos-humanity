<ul data-ref="menu" class="menu" style="background: var(--secondary);">
  {% for item in items %}
    {# regular menu item #}
    {% if not item.children %}
      <li data-item="{{loop.index}}" class="h-fit item {{- item.current ? ' current-menu-item underline underline-offset-8' }}">
        <a class="link block no-underline text-white py-sm font-normal" href="{{ item.link }}" {{ item.target == '_blank' ? 'target="_blank" rel="noopener noreferrer"' }}>
          {{ item.title }}
        </a>
      </li>
    {% endif %}
    {# menu with submenu item #}
    {% if item.children %}
      <li class="h-fit item open-submenu {{- item.current ? ' current-menu-item' }}" >
        <a class="tab-control pb-sm text-white link inline-block no-underline hover:underline underline-offset-8 text-currentColor transition-all duration-200 relative z-[9999]" 
          href="{{ item.link }}" {{ item.target == '_blank' ? 'target="_blank" rel="noopener noreferrer"' }}>
          {{ item.title }}
        </a>
        <ul class="submenu w-full px-0 py-sm z-50" style="background: var(--secondary);">
          {% for subitem in item.children %}
            <li class="h-fit mb-sm border-b border-white item {{- subitem.current ? ' current-menu-item' }} {{ subitem.classes|join(' ') }}">
              <a class="link pb-sm text-white font-normal inline-block no-underline text-currentColor transition-all duration-200" href="{{ subitem.link }}">{{ subitem.title }}</a>
            </li>
          {% endfor %}
        </ul>
      </li>
    {% endif %}
  {% endfor %}
</ul>
