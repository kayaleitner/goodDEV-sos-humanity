<ul data-ref="menu" class="menu" style="background: var(--secondary);">
  {% for item in items %}
    <li class="item {{- item.current ? ' current-menu-item' }}">
      <a class="link block h4 no-underline text-white py-sm font-normal" href="{{ item.link }}" {{ item.target == '_blank' ? 'target="_blank" rel="noopener noreferrer"' }}>{{ item.title }}</a>
    </li>
  {% endfor %}
</ul>
