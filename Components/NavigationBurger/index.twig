<flynt-component
    class="md:hidden relative"
    load:on="idle"
    load:on:media="(max-width: 980px)"
    name="NavigationBurger">
  <nav data-ref="nav" class="h-full text-bgColor" aria-label="{{ labels.ariaLabel|e }}">
    <div class="fixed top-0 left-0 z-[49] container mx-auto flex items-center justify-between py-[7px]">
      {% include 'Partials/_logo.twig' with { 'logo': logo, 'logo_dark': logo_dark, 'site': site } only %}
      {% if ctaLink or menu %}
        <div class="flex gap-xs items-center">
          {% if ctaLink %}
            <div data-ref="cta" class="top-0 transition-[top] transition-delay-75 duration-300 ease-in-out relative">
              {% include 'Partials/_cta.twig' with { 'ctaLink': ctaLink } only %}
            </div>
          {% endif %}
          {% if menu %}
            {% include 'Partials/_hamburger.twig' with { 'labels': labels } only %}
          {% endif %}
        </div>
      {% endif %}
    </div>
    {% if menu %}
      {% include 'Partials/_menu.twig' with { 'items': menu.items, 'ctaLink': ctaLink  } only %}
    {% endif %}
  </nav>
</flynt-component>
