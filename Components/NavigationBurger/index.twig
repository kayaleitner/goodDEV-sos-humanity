<flynt-component class"flyntComponent" is="flynt-navigation-burger" name="NavigationBurger">
  <nav aria-label="{{ __("Main", "flynt") }}">
    <div class="container" style="max-width: {{ containerMaxWidth }};">
      {% include 'Partials/_logo.twig' with { 'logo': logo, 'site': site } only %}
      <div class="right">
      {% if menu %}
        {% if ctaLink and ctaText %}
          <div class="cta">{% include 'Partials/_cta.twig' ignore missing with {ctaLink: ctaLink, ctaText: ctaText} only %}</div>
        {% endif %}
        {% if social %}
          <div class="social">{% include 'Partials/_social.twig' ignore missing with {social: social} only %}</div>
        {% endif %}
        {% include 'Partials/_hamburger.twig' with { 'a11y': a11y } only %}
      {% endif %}
      </div>
    </div>
    {% if menu %}
      <ul class="menu">
        {% for item in menu.items %}
          {# regular menu item #}
          {% if not item.children %}
            <li class="menu-item {{ item.current ? 'menu-item--current' }} h3">
              <a class="menu-link" href="{{ item.link }}" {{ item.target == '_blank' ? 'target="_blank" rel="noreferrer noopener"' }}>
                {{ item.title }}
              </a>
            </li>
          {% endif %}
          {# menu with submenu item #}
          {% if item.children %}
            <li class="menu-item open-submenu {{ item.current ? 'menu-item--current' }} h3" href="{{ item.link }}">
              <a class="menu-link" data-slug="{{item.slug}}" id="sub-{{item.slug}}" href="{{ item.link }}" {{ item.target == '_blank' ? 'target="_blank" rel="noreferrer noopener"' }}>
                {{ item.title }}
              </a>
              <ul class="menu-submenu" aria-hidden="true" id="content-{{ loop.index }}">
                {% for subitem in item.children %}
                  <li class="menu-item {{ subitem.current ? 'menu-item--current' }} h3">
                    <a class="menu-link" href="{{ subitem.link }}">{{ subitem.title }}</a>
                  </li>
                {% endfor %}
              </ul>
            </li>
            {% endif %}
        {% endfor %}
        {{ renderComponent('NavigationPreNav') }}
      </ul>
    {% endif %}
  </nav>
</flynt-component>