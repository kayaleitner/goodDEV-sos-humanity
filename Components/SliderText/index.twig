<flynt-component
  load:on="idle" name="SliderText"
  class="pb-0 lg:pb-xl overflow-hidden"
  {{ options.navStyle ? 'data-navStyle="' ~ options.navStyle ~ '"' }}
>
  <script type="application/json">{{ jsonData|json_encode }}</script>
  <div class="max-w-screen-max w-full mx-auto p-sm lg:p-lg">
    {% if blockTitle %}
      <div class="pb-sm lg:pb-md h4">{{ blockTitle }}</div>
    {% endif %}
    <div data-ref="slider" class="slider swiper-container">
      <div class="button-wrapper absolute right-0 lg:right-0 top-0 flex align-middle justify-end">
        <button type="button" data-ref="prev" class="slider-button slider-button--prev">
          <svg width="40" height="30" viewBox="0 0 40 30" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3.93801 13.9393C3.35222 14.5251 3.35222 15.4749 3.93801 16.0607L13.4839 25.6066C14.0697 26.1924 15.0195 26.1924 15.6053 25.6066C16.1911 25.0208 16.1911 24.0711 15.6053 23.4853L7.11999 15L15.6053 6.51472C16.1911 5.92893 16.1911 4.97918 15.6053 4.3934C15.0195 3.80761 14.0697 3.80761 13.484 4.3934L3.93801 13.9393ZM34.3438 13.5L4.99867 13.5L4.99867 16.5L34.3437 16.5L34.3438 13.5Z" fill="black"/>
          </svg>
        </button>
        <button type="button" data-ref="next" class="slider-button slider-button--next">
          <svg width="32" height="23" viewBox="0 0 32 23" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M30.7182 12.631C31.304 12.0452 31.304 11.0954 30.7182 10.5097L21.1723 0.963714C20.5865 0.377927 19.6368 0.377927 19.051 0.963713C18.4652 1.5495 18.4652 2.49925 19.051 3.08503L27.5363 11.5703L19.051 20.0556C18.4652 20.6414 18.4652 21.5911 19.051 22.1769C19.6368 22.7627 20.5865 22.7627 21.1723 22.1769L30.7182 12.631ZM0.3125 13.0703L29.6576 13.0703L29.6576 10.0703L0.3125 10.0703L0.3125 13.0703Z" fill="black"/>
          </svg>
        </button>
      </div>
      <div class="swiper-wrapper">
        {% for box in contentBoxes %}
          <div class="slider-item swiper-slide p-sm lg:p-md lg:mr-md text-white flex flex-col justify-between" style="background: {{ box.panelTextboxbgcolor }};">
            {% if box.panelTextbox %}<div class="h5">{{ box.panelTextbox|e('wp_kses_post') }}</div>{% endif %}
            {% if box.panelLogo %}
              <div class="">
                <img class="logo lazyload w-auto max-w-[w00px]"
                src="{{ box.panelLogo.src | resize(32) }}"
                data-srcset="{{function('wp_get_attachment_image_srcset', box.panelLogo.id)}}"
                data-sizes="auto">
              </div>
            {% endif %}
            {% if box.panelAuthor %}<div class="h6">{{ box.panelAuthor }}</div>{% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</flynt-component>
