<flynt-component class="overflow-hidden pb-0 lg:pb-xl" load:on="idle" name="SliderText" {{ options.navStyle ? 'data-navStyle="' ~ options.navStyle ~ '"' }}>
  <script type="application/json">{{ jsonData|json_encode }}</script>
  <div class="mx-auto max-w-screen-max p-0 xs:p-sm md:p-md lg:p-lg">
    {% if blockTitle %}
      <h2 class="hidden xs:block !leading-subtitle pb-sm lg:pb-md text-black font-bold subtitle block-title z-50">{{ blockTitle }}</h2>
    {% else %}
      <div class="hidden xs:block pb-sm lg:pb-md h-[75px]"></div>
    {% endif %}
    <div class="swiper-container relative slider max-w-full" data-ref="slider">
      {% if blockTitle %}
        <h2 class="block xs:hidden absolute top-md left-sm lg:pb-md subtitle block-title font-bold z-50" style="color: {% if options.colorSecondary %}{{ options.colorSecondary }}{% else %}var(--black){% endif %};">{{ blockTitle }}</h2>
      {% endif %}
      <div class="absolute right-sm xs:right-0 flex justify-end items-center z-50 translate-y-[32px] xs:-translate-y-[45px] lg:-translate-y-[60px] button-wrapper">
        <button type="button" data-ref="prev" class="flex items-center justify-center cursor-pointer z-[10] slider-button slider-button--prev">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="30" viewBox="0 0 40 30" fill="none">
            <path style="fill: {% if options.colorSecondary %}{{ options.colorSecondary }}{% else %}var(--black){% endif %};" d="M3.93801 13.9393C3.35222 14.5251 3.35222 15.4749 3.93801 16.0607L13.4839 25.6066C14.0697 26.1924 15.0195 26.1924 15.6053 25.6066C16.1911 25.0208 16.1911 24.0711 15.6053 23.4853L7.11999 15L15.6053 6.51472C16.1911 5.92893 16.1911 4.97918 15.6053 4.3934C15.0195 3.80761 14.0697 3.80761 13.484 4.3934L3.93801 13.9393ZM34.3438 13.5L4.99867 13.5L4.99867 16.5L34.3437 16.5L34.3438 13.5Z"/>
          </svg>
        </button>
        <button type="button" data-ref="next" class="flex items-center justify-center cursor-pointer z-[10] slider-button slider-button--next">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="30" viewbox="0 0 40 30" fill="none">
            <path style="fill: {% if options.colorSecondary %}{{ options.colorSecondary }}{% else %}var(--black){% endif %};" d="M3.93801 13.9393C3.35222 14.5251 3.35222 15.4749 3.93801 16.0607L13.4839 25.6066C14.0697 26.1924 15.0195 26.1924 15.6053 25.6066C16.1911 25.0208 16.1911 24.0711 15.6053 23.4853L7.11999 15L15.6053 6.51472C16.1911 5.92893 16.1911 4.97918 15.6053 4.3934C15.0195 3.80761 14.0697 3.80761 13.484 4.3934L3.93801 13.9393ZM34.3438 13.5L4.99867 13.5L4.99867 16.5L34.3437 16.5L34.3438 13.5Z"/>
          </svg>
        </button>
      </div>
      <div class="slider-pagination block xs:hidden swiper-pagination-fraction" data-ref="dots" style="color: {% if options.colorSecondary %}{{ options.colorSecondary }}{% else %}var(--black){% endif %};"></div>
      <div class="swiper-wrapper box-inherit">
        {% for box in contentBoxes %}
          <div class="box-border !flex flex-col justify-between item gap-[40px] min-h-[450px] overflow-hidden p-sm lg:p-md lg:mr-md relative w-full fade-in move-up" style="background-color: {% if box.colorBackground %}{{ box.colorBackground }}{% else %}var(--secondary){% endif %}; color:{% if box.colorText %}{{ box.colorText }}{% else %}var(--white){% endif %};">
            <div class="block xs:hidden py-sm"></div>
            {% if box.panelTextbox %}
              <div class="wysiwyg">{{ box.panelTextbox|e('wp_kses_post') }}</div>
            {% endif %}
            <div>
              {% if box.panelLogo %}
                <div class="">
                  <img class="lazyload w-auto h-[45px] object-contain {% if box.logoFilter %} brightness-0 invert {% endif %} logo" src="{{ box.panelLogo.src | resize(32) }}" data-srcset="{{function('wp_get_attachment_image_srcset', box.panelLogo.id)}}" data-sizes="auto">
                </div>
              {% endif %}
              {% if box.panelAuthor %}<div class="caption mt-md" style="color:{% if box.colorText %}{{ box.colorText }}{% else %}var(--white){% endif %};">{{ box.panelAuthor }}</div>{% endif %}
            </div>
            <div class="block xs:hidden py-xs"></div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</flynt-component>