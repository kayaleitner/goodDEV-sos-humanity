<flynt-component 
  load:on="visible" 
  name="BlockInsightHeader" 
  class="w-full mx-auto flex flex-col md:flex-row gap-lg" 
  data-navStyle="light-blur">
  {# Left Column #}
  <section class="w-full md:w-2/3 flex flex-col gap-lg">
    {% if post.thumbnail %}
      <div class="featuredImage w-full">
        <img class="figure-image lazyload h-full w-full object-cover"
          src="{{ post.thumbnail.src | resize(32) }}"
          data-srcset="{{function('wp_get_attachment_image_srcset', post.thumbnail.id)}}"
          data-sizes="auto">
      </div>
    {% endif %}
    <div class="w-full flex flex-col gap-md">
      <div class="w-full flex flex-row justify-between align-middle items-center">
        <div class="h6"><span class="font-bold">{{ post.date("d.m.Y") }}</span></div>
        <div class="h6"><span class="font-bold underline">{{ post.category }}</span></div>
      </div>
      {% if post.specialTitle %}
        <h1 class="h2 font-bold">{{ post.specialTitle }}</h1>
      {% else %}
        <h1 class="h2 font-bold">{{ post.title }}</h1>
      {% endif %}
      {% if post.post_excerpt %}
        <div class="hidden md:block w-full">
          <div class="h3">{{ post.post_excerpt }}</div>
        </div>
      {% endif %}
    </div>
  </section>
  {# Right Column #}
  <section class="w-full md:w-1/3 flex flex-col gap-md">
    <div class="facts w-full flex flex-col md:flex-row lg:flex-col gap-lg items-center"> {# Facts Box #}
      <div class="h6 w-full border border-black p-sm flex flex-col">
        <span class="pb-sm font-bold border-b">{{ post.factBoxTitle }}</span>
        <div class="factsflex flex-col">
          {% for item in post.facts %}
            <div class="py-sm flex flex-row gap-lg justify-between items-center border-b border-black">{{ item.factTextarea }}</div>
          {% endfor %}
          {% if post.download %}
            <div class="pt-sm">
              <a class="download button button--outlineBlack" href="{{ post.download.url|e }}" alt="{{ post.download.alt|e }}" target="_blank" rel="noreferrer noopener">
                {{ post.downloadLinkLabel|e }}
              </a>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
    {# Authors Section #}
    <div class="authors w-full flex flex-col md:flex-row lg:flex-col gap-lg items-center">
      <div class="w-full flex flex-col">
        <span class="h3 pb-sm font-bold">{{ post.authorsBoxTitle }}</span>
        <div class="flex flex-col">
          {# Internal Author #}
          {% for item in Post(post.internalAuthorz) %}
            <div class="w-full pb-xs">
              <div class="w-full py-xs flex flex-row gap-sm border-t border-lightgrey">
                <img
                  class="aspect-square object-cover w-1/3 grayscale"
                  src="{{ item.thumbnail.src }}"
                  data-srcset="{{function('wp_get_attachment_image_srcset', item.thumbnail.id)}}"
                  data-sizes="auto">
                <div class="h6 w-2/3 flex flex-col">
                  <div class="font-bold">{{ item.title }}</div>
                  <div>Position</div>
                </div>
              </div>
              <div class="flex justify-end items-center">
                <a href="{{ item.link }}" class="button button--arrow"></a>
              </div>
            </div>
          {% endfor %}
          {# External Author #}
          {% for item in post.authorz %}
            <div class="w-full pb-xs">
              <div class="w-full py-xs flex flex-row gap-sm border-t border-lightgrey">
                {% if item.authorImage %}
                <img
                  class="aspect-square object-cover w-1/3 grayscale"
                  src="{{ item.authorImage.src }}"
                  data-srcset="{{function('wp_get_attachment_image_srcset', item.authorImage.id)}}"
                  data-sizes="auto">
                {% endif %}
                {% if item.authorName or item.authorPosition %}
                <div class="h6 w-2/3 flex flex-col">
                  <div class="font-bold">{{ item.authorName }}</div>
                  <div>{{ item.authorPosition }}</div>
                </div>
                {% endif %}
              </div>
              {% if item.authorLink %}
              <div class="flex justify-end items-center">
                <a href="{{ item.authorLink }}" class="button button--arrow" target="_blank" rel="noreferrer noopener"></a>
              </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </section>
</flynt-component>
