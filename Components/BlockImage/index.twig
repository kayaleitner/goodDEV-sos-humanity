<flynt-component load:on="visible" name="BlockImage" class="w-full lg:w-2/3 py-lg">
  <figure class="figure">
    <img class="figure-image lazyload h-full w-full object-cover"
        src="{{ image.src | resize(32) }}"
        data-srcset="{{function('wp_get_attachment_image_srcset', image.id)}}"
        data-sizes="auto"
        alt="{{ image.alt|e }}">
    {% if image.caption %}
      <figcaption class="caption">{{ image.caption|e }}</figcaption>
    {% endif %}
  </figure>
</flynt-component>
