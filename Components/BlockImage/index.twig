<div class="flyntComponent flyntComponent--{{ options.size }} {{ options.theme }} {{ noComponentSpacing == true ? '' : 'componentSpacing' }}" is="flynt-block-image">
  <div class="container{% if options.size != 'sizeFull' %} {% endif %} {% if options.fadeIn %} fade-in {% endif %} {% if options.moveIn %} move-in {% endif %}">
    <figure class="figure">
      {% set gif = image.post_mime_type == 'image/gif' %}
      <img class="figure-image {{ not gif ? 'lazyload' }}"
        src="{{ not gif ? image.src|resizeDynamic(800) : image.src }}"
        {% if not gif %}
          src="{{ image.src | resize(32) }}"
          data-srcset="{{function('wp_get_attachment_image_srcset', image.id)}}"
          data-sizes="auto"
        {% endif %}
        alt="{{ image.alt|e }}">
      {% if image.caption %}
        <figcaption class="figure-caption">{{ image.caption|e }}</figcaption>
      {% endif %}
    </figure>
  </div>
</div>
