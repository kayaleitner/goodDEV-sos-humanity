{% if relatedProjects|length > 0 %}
<flynt-component load:on="visible" name="RelatedProjects" data-type="listing" class="">
  <div class="max-w-screen-max w-full mx-auto p-sm md:p-md lg:p-lg">
    {% if blockTitle %}
      <div class="max-w-screen-max w-full mx-auto pb-sm lg:pb-lg flex flex-row justify-between items-center content-center">
        <h2 class="subtitle block-title font-bold">{{ blockTitle }}</h2>
        <a href="{{ labels.allPostsLink.url }}" class="underline hover:no-underline caption font-bold">{{ labels.allPosts }}</a>
      </div>
    {% endif %}
    <ul class="
        w-full
        mx-auto
        grid xs:grid-cols-2 sm:grid-cols-3 
        gap-sm lg:gap-md
      ">
        {% include 'Partials/_items.twig' with {posts: posts, 'labels': labels } %}
    </ul>
  </div>
</flynt-component>
{% endif %}
