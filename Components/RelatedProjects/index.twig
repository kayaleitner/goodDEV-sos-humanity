{% if relatedProjects|length > 0 %}
<flynt-component class="" data-type="listing" load:on="visible" name="RelatedProjects">
  <div class="max-w-screen-max w-full mx-auto p-sm md:p-md lg:p-lg">
    {% if blockTitle %}
      <div class="max-w-screen-max w-full mx-auto pb-sm lg:pb-lg flex flex-row justify-between items-center content-center">
        {% include 'Components/_Atoms/Titles/blockTitle.twig' with { blockTitle: blockTitle } %}
        <a href="{{ labels.allPostsLink.url }}" class="underline hover:no-underline caption font-bold">{{ labels.allPosts }}</a>
      </div>
    {% endif %}
    <ul class="w-full mx-auto grid xs:grid-cols-2 sm:grid-cols-3 gap-sm lg:gap-md">
      {% for post in relatedProjects %}
        {% include 'Components/_Atoms/Cards/project.twig' with { 'post': post, 'labels': labels } only %}
      {% endfor %}
    </ul>
  </div>
</flynt-component>
{% endif %}