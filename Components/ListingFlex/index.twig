{% if posts|length > 0 %}
  <flynt-component load:on="visible" name="ListingFlex" data-type="listing" class="" data-navStyle="light-blur">
    <div class="max-w-screen-max w-full mx-auto p-sm lg:p-lg">
      {% if (blockTitle or viewAllLink or filters) %}
        <div class="w-full mx-auto pb-sm md:pb-lg flex flex-row justify-between align-bottom items-end content-end">
          {% if blockTitle %}
            <div class="subtitle block-title font-bold">{{ blockTitle }}</div>
          {% endif %}
          <div class="filters inline-flex gap-sm">
            {% for flexFilter in filters %}
              <label for="{{ flexFilter.name }}" class="sr-only">{{ flexFilter.label }}:</label>
              <select name="{{ flexFilter.name }}" id="{{ flexFilter.name }}" class="border-2 w-96 text-body">
                <option value="*" selected>{{ flexFilter.label }}</option>
                {% for val in flexFilter.terms %}
                  <option value="{{ val.slug }}">{{ val.name }}</option>
                {% endfor %}
              </select>
            {% endfor %}
          </div>
          {% if viewAllLink %}
            <a href="{{ viewAllLink.url }}" class="underline hover:no-underline caption font-bold">{{ viewAllLink.title }}</a>
          {% endif %}
        </div>
      {% endif %}
      <ul
        class="
          w-full
          mx-auto
          grid xs:grid-cols-2 md:grid-cols-3 xl:grid-cols-3
          gap-0 sm:gap-md
        "
      >
        {% for post in posts %}
          {% if post.type == 'post' %}
            {% include 'Atoms/Cards/post.twig' with { 'post': post, 'labels': labels } only %}
          {% endif %}
          {% if post.type == 'people' %}
            {% include 'Atoms/Cards/people.twig' with { 'post': post, 'labels': labels } only %}
          {% endif %}
          {% if post.type == 'project' %}
            {% include 'Atoms/Cards/project.twig' with { 'post': post, 'labels': labels } only %}
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  </flynt-component>
{% endif %}
