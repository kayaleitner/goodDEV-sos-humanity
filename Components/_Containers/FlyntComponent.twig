<flynt-component
  load:on="{{ componentOptions.loadOn }}"
  name="{{ componentOptions.name }}"
  class="{{ options.mediaLayout ? 'layout-{{ options.mediaLayout}}' }}{{ componentOptions.class }}"
  {{ options.theme ? 'data-theme="' ~ options.theme ~ '"' }}
  {{ options.navStyle ? 'data-navStyle="' ~ options.navStyle ~ '"' }}
  style="{% if options.colorBackground %}background:{{options.colorBackground }};{% endif %}{% if options.colorText %} color:{{ options.colorText }};{% endif %}"
>
  {{ content|raw }}
</flynt-component>