<flynt-component
  {% if options.componentId %}
    id="{{ options.componentId }}"
  {% endif %}
  load:on="{{ componentOptions.loadOn }}"
  load:on:media="{{ componentOptions.loadOnMedia }}"
  name="{{ componentOptions.name }}"
  class="
    block relative
    {{ options.mediaLayout ? 'layout-{{ options.mediaLayout}}' }}
    {{ componentOptions.class }}
  "
  {{ options.theme ? 'data-theme="' ~ options.theme ~ '"' }}
  {{ options.navStyle ? 'data-navStyle="' ~ options.navStyle ~ '"' }}
  style="
    {% if options.colorBackground %}
      background:{{options.colorBackground }};
      --bgColor:{{options.colorBackground }};
    {% endif %}{% if options.colorText %}
      color:{{ options.colorText }};
      --textColor:{{options.colorText }};
    {% endif %}"
>
  {{ content|raw }}
</flynt-component>