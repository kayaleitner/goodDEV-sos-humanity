{% import "Components/_Atoms/Titles/title/macro.twig" as h %}

{% set componentOptions = {
    name: 'BlockWysiwyg',
    loadOn: 'idle',
} %}

{% set content %}
  <div class="container-grid">
    {% if blockTitle %}
      <div class="col-span-full md:col-span-5">
          {{ h.h(blockTitle, { level: 2, class: '' }) }}
        </div>
    {% endif %}
    <div class="wysiwyg col-span-full md:col-span-8 ">
      {{ contentHtml|e('wp_kses_post') }}
    </div>
  </div>
{% endset %}


{% include 'Components/_Containers/FlyntComponent.twig' with {
    content: content,
    componentOptions: componentOptions
} %}


