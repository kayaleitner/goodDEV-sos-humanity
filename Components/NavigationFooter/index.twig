<flynt-component 
  load:on="visible" 
  name="NavigationFooter" 
  class="w-full left-0 bottom-0" 
  style="background: {% if colorBackground %}{{ colorBackground }}{% else %}var(--secondary){% endif %}; color:{% if colorText %}{{ colorText }}{% else %}var(--white){% endif %};">
  <div class="max-w-screen-max mx-auto flex flex-col px-sm py-lg lg:p-lg">
    <div class="flex flex-col lg:flex-row align-top justify-between gap-lg w-full mb-xxl">
      {% if logoFooter %}
        <a href="{{ site.link }}">
          <img class="logo lazyload w-[185px] lg:w-[250px]"
          src="{{ logoFooter.src | resize(32) }}"
          data-srcset="{{function('wp_get_attachment_image_srcset', logoFooter.id)}}"
          data-sizes="auto">
        </a>
      {% endif %}
      <div class="grow flex flex-row lg:flex-row align-top items-start justify-between lg:justify-end flex-wrap gap-lg">
        {% if addressHtml %}
          <div class="order-2 lg:order-1 w-1/4 lg:w-auto grow lg:grow-0 flex flex-col align-top items-start justify-start gap-xs lg:gap-[15px]">
            <div class="caption font-bold">{{ addressColumnTitle }}</div>
            <div class="flex flex-col gap-[15px] lg:gap-[23px] justify-between">
              <div class="caption">{{ addressHtml|e('wp_kses_post') }}</div>
              <div>
                <div class="caption text-currentColor">{{ addressEmail }}</div>
                <div class="caption text-currentColor mt-xs lg:mt-[15px]">{{ addressPhone }}</div>
              </div>
            </div>
          </div>
        {% endif %}
        {% for panelOuter in repeaterOuter %}
          <div class="order-1 lg:order-2 w-1/4 lg:w-auto grow lg:grow-0 flex flex-col align-top items-start justify-start gap-xs lg:gap-[15px]" id="content-{{ loop.index }}">
            <div class="caption font-bold">{{ panelOuter.title }}</div>
            {% for panelInner in panelOuter.repeaterInner %}
              <a class="caption inline-block no-underline hover:text-green underline-offset-8 text-currentColor transition-all duration-200" href="{{ panelInner.pageLink.url|e }}" alt="{{ panelInner.pageLink.alt|e }}" {% if panelInner.pageLink.target %} target="{{ panelInner.pageLink.target }}" rel="noreferrer noopener"{% endif %}>
                {{ panelInner.pageLink.title|e }}
              </a>
            {% endfor %}
          </div>
        {% endfor %}
        {% if social %}
          <div class="order-3 lg:hidden social w-1/4 grow lg:grow-0 flex flex-col align-top items-start justify-start gap-xs">
            {% if socialMediaTitle %}
              <div class="caption font-bold">{{ socialMediaTitle }}</div>
            {% endif %}
            <div class="flex flex-row gap-xs">
              {% for socials in social %}
                <a class="socialList-link" href="{{ socials.url }}" target="_blank" aria-label="{{ socials.platform.label }}">
                  <span data-icon="{{ socials.platform.label|lower }}-white"></span>
                </a>
              {% endfor %}
            </div>
            </ul>
          </div>
        {% endif %}
      </div>
    </div>
    <div class="flex flex-col-reverse lg:flex-row align-middle items-start lg:items-center justify-start lg:justify-between gap-lg w-full">
      {% if copyrightsHtml %}
        <div class="lg:w-2/3">{{ copyrightsHtml|e('wp_kses_post') }}</div>
      {% endif %}
      {% if social %}
        <div class="social lg:w-1/3 hidden lg:flex flex-row align-middle items-center justify-end">
          {% if socialMediaTitle %}
            <div class="caption font-bold">{{ socialMediaTitle }}</div>
          {% endif %}
          {% for socials in social %}
            <a class="socialList-link" href="{{ socials.url }}" target="_blank" aria-label="{{ socials.platform.label }}">
              <span data-icon="{{ socials.platform.label|lower }}-white"></span>
            </a>
          {% endfor %}
          </ul>
        </div>
      {% endif %}
    </div>
  <div>
</flynt-component>
