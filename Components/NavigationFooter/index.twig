<flynt-component class="w-full left-0 bottom-0" load:on="visible" name="NavigationFooter" style="background: {% if colorBackground %}{{ colorBackground }}{% else %}var(--secondary){% endif %}; color:{% if colorText %}{{ colorText }}{% else %}var(--white){% endif %};">
  <div class="max-w-screen-max mx-auto px-sm py-lg lg:p-lg flex flex-col">
    <div class="flex flex-col lg:flex-row gap-lg justify-between items-start w-full mb-xxl">
      {% if logoFooter %}
        <a href="{{ site.link|e('esc_url') }}">
          <img class="logo lazyload w-[185px] lg:w-[250px]"
          src="{{ logoFooter.src | resize(32) }}"
          data-srcset="{{function('wp_get_attachment_image_srcset', logoFooter.id)}}"
          data-sizes="auto">
        </a>
      {% endif %}
      <div class="flex flex-row lg:flex-row gap-lg justify-between items-start lg:justify-end flex-wrap">
        {% if addressHtml %}
          <div class="flex flex-col gap-xs lg:gap-[15px] order-2 lg:order-1 w-1/4 lg:w-auto grow lg:grow-0 items-start justify-start">
            <div class="caption font-bold">{{ addressColumnTitle }}</div>
            <div class="flex flex-col justify-between gap-[15px] lg:gap-[23px]">
              <div class="caption">{{ addressHtml|e('wp_kses_post') }}</div>
              <div>
                <div class="caption text-currentColor">{{ addressEmail }}</div>
                <div class="caption text-currentColor mt-xs lg:mt-[15px]">{{ addressPhone }}</div>
              </div>
            </div>
          </div>
        {% endif %}
        {% for panelOuter in repeaterOuter %}
          <div class="flex flex-col gap-xs lg:gap-[15px] order-1 lg:order-2 w-1/4 lg:w-auto grow lg:grow-0 items-start justify-start" id="content-{{ loop.index }}">
            <div class="caption font-bold">{{ panelOuter.title }}</div>
            {% for panelInner in panelOuter.repeaterInner %}
              <a class="caption inline-block no-underline underline-offset-8 hover:text-green text-currentColor transition-all duration-200" href="{{ panelInner.pageLink.url|e }}" alt="{{ panelInner.pageLink.alt|e }}" {% if panelInner.pageLink.target %} target="{{ panelInner.pageLink.target }}" rel="noreferrer noopener"{% endif %}>
                {{ panelInner.pageLink.title|e }}
              </a>
            {% endfor %}
          </div>
        {% endfor %}
        {% if social %}
          <div class="flex flex-col gap-xs order-3 lg:hidden w-1/4 grow lg:grow-0 items-start justify-start social">
            {% if socialMediaTitle %}
              <div class="caption font-bold">{{ socialMediaTitle }}</div>
            {% endif %}
            <div class="flex flex-row gap-xs">
              {% for socials in social %}
                <a class="socialList-link" href="{{ socials.url }}" target="_blank" aria-label="{{ socials.platform.label }}">
                  <span data-icon="{{ socials.platform.label|lower }}-white"></span>
                </a>
              {% endfor %}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
    <div class="flex flex-col-reverse lg:flex-row gap-lg justify-start items-start lg:items-center w-full">
      <div class="lg:w-2/3">© {{ 'now' | date('Y') }} {{ site.name }}</div>
      {% if social %}
        <div class="hidden lg:flex flex-row items-center justify-end social lg:w-1/3">
          {% if socialMediaTitle %}
            <div class="caption font-bold">{{ socialMediaTitle }}</div>
          {% endif %}
          {% for socials in social %}
            <a class="socialList-link" href="{{ socials.url }}" target="_blank" aria-label="{{ socials.platform.label }}">
              <span data-icon="{{ socials.platform.label|lower }}-white"></span>
            </a>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</flynt-component>
