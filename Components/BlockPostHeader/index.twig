<div class="flyntComponent" is="flynt-block-post-header">
  <div class="container">
    <div class="content">
      <h2 class="h3">{{ post.title }}</h2>
      {% if post.thumbnail and (post.type == 'post' or post.type == 'job') %}
        <div class="featuredImage">
          {{ renderComponent('BlockImage', { image: post.thumbnail, options: { size: 'sizeFull' }, noComponentSpacing: true }) }}
        </div>
      {% endif %}
      <div class="meta">
      {% if post.field_meta_date and (post.type == 'post') %}

         <time class="meta-date" datetime="{{ post.field_meta_date }}"
            style="
              background: var(--blue);
              color: var(--warmwhite);
              padding: 4px 10px;
              border-radius: 0px;
              font-style: normal;
              "
            >
            {{ post.field_meta_date|date('d.m.y') }}
          </time>          
        {% endif %}
        
        {# {{ labels.postedByLabel|e }} <a class="meta-author" href="{{ post.author.link|e('esc_url') }}"><span class="visuallyHidden">{{ __("Author:", "flynt") }}</span> {{ post.author.name }}</a>
        {{ labels.postedInLabel|e }} <a class="meta-category" href="{{ post.category.link|e('esc_url') }}"><span class="visuallyHidden">{{ __("Category:", "flynt") }}</span> {{ post.category }}</a>
        {{ dividers.readingtimeDivider|e }} <span class="meta-readingtime">{{ post.content|readingtime }} 
        {{ labels.readingtimeLabel|e }}</span> #}
      </div>
      {# {% if post.content|wp_kses_custom %}
        {{ post.content|wp_kses_custom }}
      {% endif %} #}
      {# {% if post.post_excerpt %}
        <p class="excerpt h3">{{ post.post_excerpt }}</p>
      {% endif %} #}
    </div>
  </div>
  
</div>
 