<div class="footer-infovisual">
  <div class="upper-footer-bar">
    <div class="infovisual-footer">
      <div class="wave-container">
        <div class="background"></div>
        <svg viewbox="0 0 1920 400"><path d=""></path></svg>
        <svg viewbox="0 0 1920 400"><path d=""></path></svg>
        <svg viewbox="0 0 1920 400"><path d=""></path></svg>
        <svg viewbox="0 0 1920 400"><path d=""></path></svg>
      </div>
    </div>
  </div>
</div>
<div class="flyntComponent" is="flynt-navigation-footer-columns">
  <div class="container" style="padding: var(--padding_small); max-width: var(--maxWidthContainer_wide);">
    <div class="columns">
      <div class="columns-menu">
        {% if menuPreContent %}
          <div class="preContent h5">
            {{ menuPreContent|e }}
          </div>
        {% endif %}
        {% include "Partials/_menu.twig" with { items: menu.items } %}
        <div class="social">
          {% if socialPreContent %}
            <div class="preContent h5">
              {{ socialPreContent|e }}
            </div>
          {% endif %}
          {% if social %}
            <ul class="socialList">
              {% for socials in social %}
                <li class="socialList-item">
                  <a class="socialList-link" href="{{ socials.url }}" aria-label="{{ socials.platform.label }}" target="_blank">
                    {{- socials.icon -}}
                  </a>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      </div>
      <div class="columns-newsletter">
        {% if newsletterPreContent %}
          <div class="preContent h5">
            {{ newsletterPreContent|e }}
          </div>
          {{ newsletter }}
        {% endif %}
      </div>
    </div>
  </div>
</div>
