<nav class="menu">
  <ul class="list">
    {% for item in menu.items %}
      {# regular menu item #}
      {% if not item.children %}
        <li class="menu-item {{ item.current ? 'menu-item--current' }} body-2">
          <a class="menu-link" href="{{ item.link }}" {{ item.target == '_blank' ? 'target="_blank" rel="noreferrer noopener"' }}>
            {{ item.title }}
          </a>
        </li>
      {% endif %}
      {# menu with submenu item #}
      {% if item.children %}
        <li class="menu-item open-submenu {{ item.current ? 'menu-item--current' }} body-2" >
          <div class="menu-link" data-slug="{{item.slug}}" id="sub-{{item.slug}}">
            {{ item.title }}
          </div>
          <ul class="menu menu-submenu">
            {% for subitem in item.children %}
              <li class="menu-item {{ subitem.current ? 'menu-item--current' }} body-2">
                <a class="menu-link" href="{{ subitem.link }}">{{ subitem.title }}</a>
              </li>
            {% endfor %}
          </ul>
        </li>
      {% endif %}
    {% endfor %}
  </ul>
</nav>
