{% import "Components/_Atoms/Titles/title/macro.twig" as h %}

{% set componentOptions = {
    name: 'BlockCards',
    loadOn: 'idle',
} %}

{% set content %}
  {% set hasText = content.blockTitle or content.textContent %}

  <div class="container-grid mx-auto">

    {% if content.textContent or content.blockTitle %}
      <div class="col-span-full">
        {% if content.blockTitle %}
          {{ h.h(content.blockTitle, { level: 2, class: 'mb-sm' }) }}
        {% endif %}
        {% if content.textContent %}
        <p class="font-paragraph">
          {{ content.textContent|e('wp_kses_post') }}
        </p>
        {% endif %}
      </div>
    {% endif %}

    {% if cards %}
      {% set layoutCardClass = '' %}
      {% if options.layout == '3col' %}
        {% set layoutCardClass = 'col-span-full md:col-span-4' %}
      {% elseif options.layout == '4col' %}
        {% set layoutCardClass = 'col-span-3' %}
      {% endif %}

      {% for card in cards %}
        <div class="anim-move-up rounded border {{ layoutCardClass }}" style="background-color: {{card.bgColor}}; color: {{card.color}};">
          <div class="flex flex-col gap-md p-md">

            <div class="w-full h-extra flex overflow-hidden">
              {% if card.image %}
                <img class="w-full h-full object-contain object-left" src="{{ card.image.src }}" alt="{{ card.image.alt }}"
                  src="{{ card.image.src|resize(32) }}" 
                  data-srcset="{{ function('wp_get_attachment_image_srcset', card.image.id) }}" 
                  data-sizes="auto" 
                  data-src="{{ card.image.src }}" 
                  alt="{{ card.image.alt|e }}"
                />
              {% endif %}
            </div>

            {% if card.title or card.text %}
            <div>
              {% if card.title %}
                {{ h.h(card.title, { level: 3, class: 'relative font-titleSub mb-md' }) }}
              {% endif %}
              {% if card.text %}
                <p class="font-paragraph">{{ card.text }}</p>
              {% endif %}
            </div>
            {% endif %}

          </div>
        </div>
      {% endfor %}

  {% endif %}
  </div>
{% endset %}


{% include 'Components/_Containers/FlyntComponent.twig' with {
    content: content,
    componentOptions: componentOptions
} %}
