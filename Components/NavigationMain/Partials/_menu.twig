<ul class="menu grow list-none flex flex-row align-top gap-md justify-start w-1/2 h-fit text-white">
  {% for item in items %}
    {# regular menu item #}
    {% if not item.children %}
      <li class="h-fit flex align-middle items-start justify-center grow item {{- item.current ? ' current-menu-item underline underline-offset-8' }}">
        <a class="link inline-block no-underline hover:underline underline-offset-8 text-currentColor transition-all duration-200" href="{{ item.link }}" {{ item.target == '_blank' ? 'target="_blank" rel="noopener noreferrer"' }}>
          {{ item.title }}
        </a>
      </li>
    {% endif %}
    {# menu with submenu item #}
    {% if item.children %}
      <li class="h-fit item open-submenu {{- item.current ? ' current-menu-item' }}" >
        <a class="link inline-block no-underline hover:underline underline-offset-8 text-currentColor transition-all duration-200" href="{{ item.link }}" {{ item.target == '_blank' ? 'target="_blank" rel="noopener noreferrer"' }}>
          {{ item.title }}
        </a>
        <ul class="menu submenu">
          {% for subitem in item.children %}
            <li class="h-fit item {{- item.current ? ' current-menu-item' }}">
              <a class="link inline-block no-underline hover:underline underline-offset-8 text-currentColor font-normal transition-all duration-200" href="{{ subitem.link }}">{{ subitem.title }}</a>
            </li>
          {% endfor %}
        </ul>
      </li>
    {% endif %}
  {% endfor %}
</ul>
