{% import "Components/_Atoms/Button/macro.twig" as btn %}

<flynt-component
    class="hidden md:block"
    load:on="load"
    load:on:media="(min-width: 980px)"
    x-data="{ menuOpen: false }"
    name="NavigationMain"
>
  <nav data-ref="nav" class="text-bgColor" aria-label="{{ labels.ariaLabel|e }}" >
    <div class="container mx-auto flex items-center justify-between py-sm">
      <a class="no-underline" href="{{ site.link|e('esc_url') }}">
        <img data-ref="logo" class="h-[48px] w-[172px]" src="{{ logo.src }}" alt="{{ logo.alt }}">
        <img data-ref="logoDark" class="hidden h-[48px] w-[172px]" src="{{ logo_dark.src }}" alt="{{ logo_dark.alt }}">
      </a>
        {% if menu %}
        <ul class="flex items-center gap-[50px] font-bodySmall h-[52px]">
          {% for item in menu.items %}
          <li>
            {% if 'button'  in item.classes|join(' ') %}
              {{ btn.buttonAnchor({ url: item.url, title: item.title }, {
                class: '',
                color: 'accent',
                style: 'outline',
                icon: true,
              }) }}
            {% else %}
            <a class="{{ item.classes|join(' ')}} no-underline after-marker after-marker--small hover:after-marker-active !transition-none"
                href="{{ item.url|e }}"
                title="{{ item.title|e }}">
                  {{ item.title|e }}
            </a>
            {% endif %}
          </li>
          {% endfor %}
          {% if ctaLink %}
          <li>
            {{ btn.buttonAnchor({ url: ctaLink.url, title: ctaLink.title }, {
                class: '',
                color: 'accent',
                style: 'outline',
                icon: true,
              }) }}
          </li>
          {% endif %}
      {% endif %}
    </div>
  </nav>
</flynt-component>
