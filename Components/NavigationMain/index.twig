{% import "Components/_Atoms/Button/macro.twig" as btn %}

{% set componentOptions = {
    name: 'NavigationMain',
    loadOn: "load",
    loadOnMedia: "(min-width: 1180px)",
    class: "hidden md:block"
} %}

{% set content %}
    <div class="container-flex pt-md justify-center items-center relative h-[8.75rem]">

    <a class="h-md absolute left-lg" href="{{ site.link|e('esc_url') }}">
      <img data-ref="logo" class="h-full" src="{{ logo.src }}" alt="{{ logo.alt }}">
      <img data-ref="logoSecondary" class="hidden h-full" src="{{ logo_secondary.src ? logo_secondary.src : logo.src }}" alt="{{ logo_secondary.alt }}">
    </a>

    <nav data-ref="nav" class="bg-paperColor rounded border border-borderColor fixed" aria-label="{{ labels.ariaLabel|e }}" >
      {% if menu %}
        <ul class="flex items-center gap-3 p-2 rounded text-textColor" x-data="{ openSubmenu: null }">

          {% for item in menu.items %}
              <li
                class="relative"
                x-data="{ id: {{ loop.index }} }" @mouseenter="openSubmenu = id" @mouseleave="openSubmenu = null">
                <button class="px-6 py-2 no-underline rounded {{ item.current ? '!underline' }} text-brandColor hover:text-textColor !transition-none relative z-20">
                   <a class="no-underline font-mainMenuText"
                    href="{{ item.url|e }}"
                    title="{{ item.title|e }}">
                      {{ item.title|e }}
                </a>
                </button>

            {% if item.children %}
                <ul x-show="openSubmenu === id" x-cloak class="absolute z-20 top-8 bg-bgColor text-textColor p-sm rounded">
                  
                  {% for subitem in item.children %}
                    <li>
                      <a class="no-underline font-mainMenuText !transition-none hover:text-[var(--randomHoverColorSubmenu)] hover:opacity-[0.7]"
                          href="{{ subitem.url|e }}"
                          title="{{ subitem.title|e }}">
                            {{ subitem.title|e }} <br />
                            {{ subitem.description|e }}
                      </a>
                      {% if not loop.last %}
                        <div class="my-[30px] border-b border-black w-full"></div>
                      {% endif %}
                    </li>
                  {% endfor %}

                </ul>
              </li>
            {% endif %}

          {% endfor %}

          {% if ctaLink %}
          <li class="mr-1">
            {{ btn.buttonAnchor(ctaLink, {
                class: ctaLink.url == '#' ? 'button-newsletter' : '',
                color: 'accent',
                style: post.navOnLight ? '' : 'outline',
                icon: true,
              }) }}
          </li>
          {% endif %}

        </ul>
      {% endif %}

    </nav>
  </div>
{% endset %}

{% include 'Components/_Containers/FlyntComponent.twig' with {
    content: content,
    componentOptions: componentOptions
} %}
