
<div class="flyntComponent {{ options.theme }}" style="--themeBrand_colorBackground: {{ options.colorBrandBackground }}; --themeBrand_colorText: {{ options.colorBrandText }};" is="flynt-block-image-text-page-link" 
name="BlockImageTextPageLink"
>
  <div class="container" style="padding: var(--padding_small); max-width: var(--maxWidthContainer_wide);">
    {% if preContent %}
      <div class="preContent h1 {% if options.fadeIn %} fade-in {% endif %} {% if options.moveIn %} move-in {% endif %}">
        {{ preContent|e }}
      </div>
    {% endif %}

    <a class="box box--{{ imagePosition }} {% if options.fadeIn %} fade-in {% endif %} {% if options.moveIn %} move-in {% endif %}" href="{{ item.link }}" aria-hidden="true" tabindex="-1">
      <div class="box-inner box-inner--image" aria-hidden="true" tabindex="-1">
        <img class="figure-image lazyload"
          src="{{ item.thumbnail.src | resize(32) }}"
          data-srcset="{{function('wp_get_attachment_image_srcset', item.thumbnail.id)}}"
          data-sizes="auto"
          alt="{{ item.thumbnail.alt|e }}">
          {% if item.thumbnail.caption %}
            <figcaption class="figure-caption">{{ item.thumbnail.caption|e }}</figcaption>
          {% endif %}
      </div>
      <div class="box-inner box-inner--arrow">
        <div class="arrow"></div>
      </div>
      <div class="box-inner box-inner--content">
        <div class="box-copy">
          <h4>{{ item.title }}</h4>
          <div class="content">{{ contentHtml|wp_kses_custom }}</div>
        </div>
      </div>
    </a>
    

  </div>
</div>

