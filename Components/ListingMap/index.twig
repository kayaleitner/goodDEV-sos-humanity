{% if posts|length > 0 %}
  <flynt-component load:on="visible" name="ListingMap" class="pb-lg lg:py-xxl">
    <div class="">
      {% if blockTitle %}
        <div class="max-w-screen-max w-full mx-auto p-sm flex flex-col gap-sm justify-between align-start items-start content-start">
          <div class="h4">{{ blockTitle }}</div>
          <a href="{{ postTypeArchiveLink }}" class="underline hover:no-underline font-bold">{{ labels.allPosts }}</a>
        </div>
      {% endif %}

      <div class="max-w-screen-max w-full mx-auto p-sm flex flex-col md:flex-row gap-lg justify-between items-center">
        
        <div class="w-full md:w-3/4 flex justify-center items-center mx-auto">
          <img src="https://crossboundaryenergy.local:61988/wp-content/uploads/2023/03/map.svg">
        </div>

        <div 
          class="w-full md:w-1/4 mx-auto relative"
          x-data="{ activeSlide: 1, slides: [1, 2, 3] }"
        >
          <!-- Slides -->
          <template x-for="slide in slides" :key="slide">
            {% for post in posts %}
            <div
              x-show="activeSlide === slide"
              class="flex items-start">
              <div class="post w-full grow">
                <a class="link" href="{{ post.link }}" aria-label="{{ post.title }}">
                  {% if post.thumbnail %}
                    <figure class="figure hidden md:block">
                      <img class="image lazyload h-[400px] object-cover"
                        src="{{  post.thumbnail.src | resize(32) }}"
                        data-srcset="{{function('wp_get_attachment_image_srcset', post.thumbnail.id)}}"
                        data-sizes="auto"
                        data-src="{{ post.thumbnail.src }}"
                        alt="{{ post.thumbnail.alt|e }}">
                    </figure>
                  {% endif %}
                  <div class="content py-sm flex flex-col gap-sm justify-between items-stretch">
                    <div class="flex flex-col gap-sm">
                      <div class="w-full p-sm flex flex-row justify-between align-middle items-center border font-mono font-bold">
                        {{ post.category }}
                      </div>
                      <div class="w-full flex flex-col gap-xs justify-between align-start items-start">
                        <div>{{ post.category }}</div>
                        <h2 class="h5 w-full grow">{{ post.title }}</h2>
                      </div>
                    </div>
                    <div class="flex flex-row lg:flex-col gap-sm justify-start items-start h-full">
                      <span class="border border-black hover:bg-black hover:text-white rounded-full flex justify-center items-center w-fit py-xs px-sm">{{ labels.readMore }}</span>
                    </div>
                  </div>
                </a>
              </div>
            </div>
            {% endfor %}
          </template>
          
          
          <!-- Prev/Next Arrows -->
          {# <div class="absolute inset-0 flex">
            <div class="flex items-center justify-start w-1/2">
              <button 
                class="bg-cbegreen text-white font-bold hover:shadow-lg rounded-full w-12 h-12 -ml-6"
                x-on:click="activeSlide = activeSlide === 1 ? slides.length : activeSlide - 1">
                &#8592;
              </button>
            </div>
            <div class="flex items-center justify-end w-1/2">
              <button 
                class="bg-cbegreen text-white font-bold hover:shadow rounded-full w-12 h-12 -mr-6"
                x-on:click="activeSlide = activeSlide === slides.length ? 1 : activeSlide + 1">
                &#8594;
              </button>
            </div>        
          </div> #}

          <!-- Buttons -->
          <div class="absolute w-full flex items-center justify-center px-4">
            <template x-for="slide in slides" :key="slide">
            {% for post in posts %}
              <button
                class="flex-1 w-4 h-2 mt-4 mx-2 mb-0 rounded-full overflow-hidden transition-colors duration-200 ease-out hover:bg-teal-600 hover:shadow-lg"
                :class="{ 
                    'bg-cbegreen': activeSlide === slide,
                    'bg-blue': activeSlide !== slide 
                }" 
                x-on:click="activeSlide = slide"
              ></button>
              {% endfor %}
            </template>
          </div>
        </div>

      </div>

      {# <ul class="max-w-screen-max mx-auto px-sm lg:px-md flex flex-col lg:flex-row gap-sm lg:gap-md justify-between">
        {% for post in posts %}
          <li class="post lg:w-1/3 grow">
            <a class="link" href="{{ post.link }}" aria-label="{{ post.title }}">
              {% if post.thumbnail %}
                <figure class="figure block">
                  <img class="image lazyload h-[400px] object-cover"
                    src="{{  post.thumbnail.src | resize(32) }}"
                    data-srcset="{{function('wp_get_attachment_image_srcset', post.thumbnail.id)}}"
                    data-sizes="auto"
                    data-src="{{ post.thumbnail.src }}"
                    alt="{{ post.thumbnail.alt|e }}">
                </figure>
              {% endif %}
              <div class="content py-sm flex flex-col gap-sm justify-between items-stretch">
                <div class="flex flex-col gap-sm">
                  <div class="w-full p-sm flex flex-row justify-between align-middle items-center border font-mono font-bold">
                    {{ post.category }}
                  </div>
                  <div class="w-full flex flex-col gap-xs justify-between align-start items-start">
                    <div>{{ post.category }}</div>
                    <h2 class="h5 w-full grow">{{ post.title }}</h2>
                  </div>
                </div>
                <div class="flex flex-row lg:flex-col gap-sm justify-end items-end lg:items-start h-full">
                  <span class="border border-black hover:bg-black hover:text-white rounded-full flex justify-center items-center w-fit py-xs px-sm">{{ labels.readMore }}</span>
                </div>
              </div>
            </a>
          </li>
        {% endfor %}
      </ul> #}
    </div>
  </flynt-component>
{% endif %}
