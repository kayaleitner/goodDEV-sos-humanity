<flynt-component
  load:on="idle" 
  name="BlockCta" 
  class="w-full"
  style="background-color: {% if options.colorBackground %}{{ options.colorBackground }}{% else %}var(--white){% endif %};"
  {{ options.navStyle ? 'data-navStyle="' ~ options.navStyle ~ '"' }}
  >
  <div class="outer w-full max-w-screen-max mx-auto p-sm md:p-lg">
    <div class="wrapper lg:w-2/3 prose lg:prose-lg">
      {{ contentHtml|e('wp_kses_post') }}
      <a class="button button--primary" href="{{buttonLink.url}}">{{buttonLink.title}}</a>
    </div>
  </div>
</flynt-component>
