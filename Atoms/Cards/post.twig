<li
  class="fade-in move-up post w-full py-sm lg:py-0 border-b border-lightgrey lg:border-b-0">
  {% if post.externalResourceLink %}
  <a class="flex flex-col h-full no-underline group" href="{{ post.externalResourceLink.url }}" {% if post.externalResourceLink.target %} target="{{ post.externalResourceLink.target }}" rel="noreferrer noopener"{% endif %}>
  {% else %}
  <a class="flex flex-col h-full no-underline group" href="{{ post.link }}" aria-label="{{ post.title }}">
  {% endif %}
    <div class="flex flex-col grow" aria-label="{{ post.title }}">
      {% if post.thumbnail %}
        <div class="hidden md:block">
          <figure class="figure overflow-hidden">
            <img class="hover:scale-[1.15] hover:origin-center focus:scale-[1.15] focus:origin-center lazyload aspect-square object-cover w-full h-full transition duration-200 ease-linear"
              src="{{  post.thumbnail.src | resize(32) }}"
              data-srcset="{{function('wp_get_attachment_image_srcset', post.thumbnail.id)}}"
              data-sizes="auto"
              data-src="{{ post.thumbnail.src }}"
              alt="{{ post.thumbnail.alt|e }}">
          </figure>
        </div>
      {% endif %}
      <div class="text-black content md:aspect-square md:border md:p-sm flex flex-col gap-sm justify-start md:justify-between items-start sm:items-stretch grow">
        <div class="w-full flex flex-col justify-start align-start items-start gap-sm">
          <div class="w-full flex flex-row justify-between align-middle items-center">
            <div class="caption text-left"><span class="font-bold">{{ post.date("d.m.Y") }}</span></div>
            <div class="caption text-right"><span class="font-bold underline">{{ post.category }}</span></div>
          </div>
          <h2 class="text-bodyMobile mb-0 lg:w-full md:grow">{{ post.title }}</h2>
        </div>
        <div class="flex md:hidden flex-row md:flex-col gap-sm justify-between items-between sm:items-stretch w-full">
          <span class="flex flex-col justify-end items-end">
            {% if post.externalResourceLink %}
              <div class="button button--link">{{ post.externalResourceLink.title|e }}</div>
            {% else %}
              <div class="button button--arrow"></div>
            {% endif %}
          </span>
        </div>
        <span class="hidden md:block">
          {% if post.externalResourceLink %}
            <div class="button button--link">{{ post.externalResourceLink.title|e }}</div>
          {% else %}
            <div class="button button--arrow"></div>
          {% endif %}
        </span>
      </div>
    </div>
  {% if post.externalResourceLink %}
  </a>
  {% else %}
  </a>
  {% endif %}
</li>
