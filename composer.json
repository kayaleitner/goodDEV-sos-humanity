{
  "name": "flyntwp/flynt",
  "description": "Flynt is a WordPress theme for component-based development using Timber and Advanced Custom Fields.",
  "type": "wordpress-theme",
  "license": "MIT",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "authors": [
    {
      "name": "Bleech",
      "email": "flynt@bleech.de"
    }
  ],
  "require": {
    "php": ">=7.4",
    "flyntwp/acf-field-group-composer": "^1.1",
    "erusev/parsedown": "^1.7",
    "timber/timber": "^2.1",
    "sabberworm/php-css-parser": "^8.5"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.8"
  },
  "scripts": {
    "post-install-cmd": [
      "composer install -d plugins/facebook-capi --no-dev --no-interaction --prefer-dist",
      "./scripts/postinstall.sh"
    ],
    "post-update-cmd": [
      "@post-install-cmd"
    ]
  },
  "extra": {
    "installer-paths": {
      "vendor/{$vendor}/{$name}/": [
        "type:wordpress-muplugin",
        "type:wordpress-plugin",
        "type:wordpress-theme"
      ]
    }
  },
  "autoload": {
    "psr-4": {
      "Flynt\\": "lib/"
    }
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true
    }
  }
}
