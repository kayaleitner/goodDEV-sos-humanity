<div
    class="
        3dshape w-full h-full top-0 left-0 relative
        transition-transform duration-600 ease
    "
    data-ref="shape"
    style="
        transform: rotateY(-20deg) rotateX(15deg);
        transform-origin: 50% 100%;
        transform-style: preserve-3d;
        transition: 0.6s ease transform;
        font-size: {{ stretch / 10 }}rem;
    "
>

{% for _ in 1..20 %}

    <img
        src="{{ image.src }}" alt=""
        style="transform: translateZ({{ loop.index * 0.75 }}em) scale({{ loop.index * 0.04 + 0.7 }})"
        class="absolute"
        width="100%" height="100%"
    />

{% endfor %}

</div>