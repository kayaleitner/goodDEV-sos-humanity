{% import "Partials/_logo.twig" as logo %}
{% import "Partials/_cta.twig" as cta %}
{% import "Partials/_hamburger.twig" as hamburger %}
{% import "Partials/_menu.twig" as menu %}

{% set componentOptions = {
    name: 'NavigationBurger',
    loadOn: 'idle',
    loadOnMedia: '(max-width: 1180px)',
    class: 'md:hidden relative'
} %}

{% set content %}
  <nav 
    data-ref="nav" 
    data-on-light="{{ post.navOnLight }}" 
    class="h-full {{ not post.navOnLight ? 'text-bgColor' }}" 
    aria-label="{{ labels.ariaLabel|e }}"
  >
    <div class="fixed top-0 left-0 z-[49] container mx-auto flex items-center justify-between py-[12px] xs:py-sm">
      {% include 'Partials/_logo.twig' with { 
        'logo': logo, 
        'site': site, 
      } only %}
      
      {% if ctaLink or menu %}
        <div class="flex gap-xs xs:gap-[16px] items-center">
          {% if ctaLink %}
            <div class="top-0 transition-[top] transition-delay-75 duration-300 ease-in-out relative">
              {% include 'Partials/_cta.twig' with { 
                'ctaLink': ctaLink, 
              } only %}
            </div>
          {% endif %}
          
          {% if menu %}
            {% include 'Partials/_hamburger.twig' with { 
              'labels': labels 
            } only %}
          {% endif %}
        </div>
      {% endif %}
    </div>

    {% if menu %}
      {% include 'Partials/_menu.twig' with { 
        'items': items, 
        'ctaLink': ctaLink, 
        'social': social, 
        'image': image  
      } only %}
    {% endif %}
  </nav>
{% endset %}

{% include "Components/_Containers/FlyntComponent.twig" with {
    content: content,
    componentOptions: componentOptions
} %}