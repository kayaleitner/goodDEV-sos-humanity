{% set componentOptions = {
    name: 'BlockNewsletter',
    loadOn: 'visible',
} %}

{% set content %}
  <div class="container-flex flex-col lg:flex-row justify-between items-stretch gap-lg">
    <div class="wysiwyg w-full lg:w-1/2 ">{{ contentHtml|e('wp_kses_post') }}</div>
    <div class="w-full lg:w-1/2 flex items-center justify-end">
      {% set formShortcode = '[contact-form-7 id="' ~ formId ~ '"]' %}
      {{ formShortcode|shortcodes }}
      {# {{ contactForm }} #}
    </div>
  </div>
{% endset %}

{% include 'Components/_Containers/FlyntComponent.twig' with {
    content: content,
    componentOptions: componentOptions
} %}
