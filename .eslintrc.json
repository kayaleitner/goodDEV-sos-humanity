{
    "parser": "@babel/eslint-parser",
    "parserOptions": {
      "requireConfigFile": false,
      "babelOptions": {
        "babelrc": false,
        "configFile": false
      }
    },
    "env": {
      "browser": true,
      "node": false,
      "es6": true
    },
    "extends": [
      "airbnb-base",
      "prettier"
    ],
    "rules": {
      "no-console": "warn",
      // allow to change object properties especially in the DOM e.g. style.width = '100px'
      "no-param-reassign": ["error", { "props": false }],
    }
}